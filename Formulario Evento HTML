  <script>
    let base64Imagen = "";

    // ✅ CORRECCIÓN Bug #1: Un único addEventListener, sin onsubmit duplicado en el <form>
    document.getElementById("formularioDesviaciones").addEventListener("submit", function(event) {
      event.preventDefault();

      const formData = new FormData(this);

      const data = {
        fecha: formData.get("fecha") || "",
        unidad: formData.get("unidad") || "",
        aspecto: formData.get("aspecto") || "",
        claseEvento: formData.get("claseEvento") || "",
        severidadEvento: formData.get("severidadEvento") || "",
        empresa: formData.get("empresa") || "",
        area: formData.get("area") || "",
        lugar: formData.get("lugar") || "",
        tipificacion: formData.get("tipificacion") || "",
        desglose1: formData.get("desglose1") || "",
        detalle: formData.get("detalle") || "",
        actoCondicion: formData.get("actoCondicion") || "",
        probabilidad: formData.get("probabilidad") || "",
        severidadTexto: formData.get("severidadTexto") || "",
        criticidad: formData.get("criticidad") || "",
        diasPerdidos: formData.get("diasPerdidos") || "",
        nombreRelacion1: formData.get("nombreRelacion1") || "",
        nombreRelacion2: formData.get("nombreRelacion2") || "",
        causasInmediatas: formData.get("causasInmediatas") || "",
        causasBasicas: formData.get("causasBasicas") || "",
        accionCorrectiva: formData.get("accionCorrectiva") || "",
        accionPreventiva: formData.get("accionPreventiva") || "",
        responsable: formData.get("responsable") || "",
        fechaLimite: formData.get("fechaLimite") || "",
        status: formData.get("status") || "",
        quienReporta: formData.get("quienReporta") || "",
        nombreReportante: formData.get("nombreReportante") || "",
        areaReportante: formData.get("areaReportante") || ""
      };

      // Deshabilitar botón mientras se envía
      document.getElementById("enviarFormulario").disabled = true;
      document.getElementById("enviarFormulario").textContent = "Enviando...";

      google.script.run
        .withSuccessHandler(function(respuesta) {
          alert("✅ " + respuesta);
          document.getElementById("formularioDesviaciones").reset();
          document.getElementById("imagenPreview").src = "";
          document.getElementById("previewImagen").classList.add("hidden");
          base64Imagen = "";
          document.getElementById("enviarFormulario").disabled = false;
          document.getElementById("enviarFormulario").textContent = "Enviar";
        })
        .withFailureHandler(function(e) {
          alert("❌ Error al enviar: " + e.message);
          document.getElementById("enviarFormulario").disabled = false;
          document.getElementById("enviarFormulario").textContent = "Enviar";
        })
        .registrarFormulario(data, base64Imagen);
    });

    function mostrarImagen(event) {
      const archivo = event.target.files[0];
      if (!archivo) return;
      const lector = new FileReader();
      lector.onload = function(e) {
        document.getElementById("imagenPreview").src = e.target.result;
        document.getElementById("previewImagen").classList.remove("hidden");
        base64Imagen = e.target.result;
      };
      lector.readAsDataURL(archivo);
    }
  </script>

  <!-- ✅ CORRECCIÓN Bug #2: Solo Select2, eliminado bloque Choices.js que causaba error -->
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      $('.select-buscable').select2({
        width: '100%'
      });
    });
  </script>

