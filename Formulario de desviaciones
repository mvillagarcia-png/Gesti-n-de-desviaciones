      seccionEvidencias += `
        <tr style="background:${i % 2 === 0 ? "#f9fafb" : "#fff"};">
          <td style="padding:6px 10px;font-size:13px;">${esVideo ? "Video" : "Imagen"}${num}</td>
          <td style="padding:6px 10px;">
            <a href="${url}" target="_blank" style="color:#CE000C;font-weight:600;text-decoration:none;">${etiq}${num} &rarr;</a>
          </td>
        </tr>`;
    });
    seccionEvidencias += `</table>`;
  }

  const URL_LEVANTAMIENTO = "https://script.google.com/a/macros/cssa.com.pe/s/AKfycbzHklwqk_JE3SuMZeYB2B048lDEuceMMrccYS-uT1tv8bguvUq34vsYodK0ZYNKbMvzSQ/exec?form=trabajador";

  const cuerpoHtml = `
    <div style="font-family:Arial,sans-serif;color:#333;max-width:600px;">
      <div style="background:#111111;padding:16px 24px;">
