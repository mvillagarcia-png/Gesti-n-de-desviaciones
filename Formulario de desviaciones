  GmailApp.sendEmail(to, asunto, "", opciones);
  Logger.log("Correo enviado a: " + to + " | CC: " + ccFinal.join(", "));
}

// ==========================================
// ALERTA DE DESVIACIONES POR ÁREA
// ==========================================

function alertaDesviacionesPorArea() {
  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);
  if (hoy.getDay() === 0 || hoy.getDay() === 6) return;

  const ss   = SpreadsheetApp.getActiveSpreadsheet();
  const hoja = ss.getSheetByName("Acumulado");
  const valores = hoja.getDataRange().getValues();
  const encabezados = valores[0];

  const getCol = (n) => encabezados.findIndex(h => h.toString().trim().toUpperCase() === n.toUpperCase());

  const cols = {
    codigo:   getCol("CÓDIGO"),
    fechaLim: getCol("FECHA LÍMITE"),
    estatus:  getCol("ESTATUS FINAL"),
    email:    getCol("EMAIL RESPONSABLE"),
    detalle:  getCol("DETALLE"),
    control:  getCol("ALERTA ENVIADA")
  };

  for (let i = 1; i < valores.length; i++) {
    const fila = valores[i];
    if (fila[cols.control] !== "") continue;

    const estatus = fila[cols.estatus].toString().trim().toLowerCase();
    if (estatus !== "pendiente" && estatus !== "en plazo") continue;

    let fLimRaw = fila[cols.fechaLim];
    if (!(fLimRaw instanceof Date)) fLimRaw = new Date(fLimRaw);
    const fLim = new Date(fLimRaw.getTime());
    fLim.setHours(0, 0, 0, 0);

    const diff = Math.round((fLim.getTime() - hoy.getTime()) / (1000 * 60 * 60 * 24));

    if (diff === 2) {
      const para = fila[cols.email];
      if (!para) continue;

      const html = `<div style="font-family:sans-serif;border:1px solid #ddd;padding:15px;">
        <h2 style="color:#d9534f;">⚠️ Alerta de Vencimiento</h2>
        <p>La desviación <b>${fila[cols.codigo]}</b> vence en 2 días.</p>
        <p><b>Detalle:</b> ${fila[cols.detalle]}</p>
        <p>Por favor, responda a este correo con las evidencias.</p>
      </div>`;

      try {
        MailApp.sendEmail({
          to: para,
          cc: "evasquezp@cssa.com.pe, esuxe@cssa.com.pe, mvillagarcia@cssa.com.pe",
          subject: `RECORDATORIO: Desviación ${fila[cols.codigo]} vence en 2 días`,
          htmlBody: html
        });
        hoja.getRange(i + 1, cols.control + 1).setValue("Enviado: " + Utilities.formatDate(new Date(), "GMT-5", "dd/MM HH:mm"));
      } catch(e) {
        Logger.log("Error alerta fila " + (i + 1) + ": " + e.message);
      }
    }
  }
}


// ==========================================
// FUNCIONES AUXILIARES
// ==========================================

function guardarImagenEnCelda(base64, fila, nombreArchivo) {
  const carpetaId = "1bxN0M9JjKgzGMmLCYxWkEBW0ByIQh_0M";
  const carpeta   = DriveApp.getFolderById(carpetaId);
  const contenido = base64.split(",")[1];
  const blob      = Utilities.newBlob(Utilities.base64Decode(contenido), 'image/png', `${nombreArchivo}.png`);
  const archivo   = carpeta.createFile(blob);
  archivo.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  const url  = archivo.getUrl();
  const hoja = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Acumulado");
  hoja.getRange("AX" + fila).setFormula(`=HYPERLINK("${url}", "ver imagen")`);
  hoja.getRange("AY" + fila).setValue(url);
  return url;
}
