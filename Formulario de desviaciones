function enviarCorreo(responsable, correoResponsable, codigo, descripcion, imagenesUrls, fechaLimite, criticidad) {

  const to = correoResponsable;

  const copiaSMA = [
    "evasquezp@cssa.com.pe",
    "mvillagarcia@cssa.com.pe",
    "esuxe@cssa.com.pe"
  ];

  const equiposPorArea = {
    "CANTERAS":      ["mvargas@cssa.com.pe", "malarcon@cssa.com.pe"],
    "MANTENIMIENTO": ["rlimaymanta@cssa.com.pe", "mmuro@cssa.com.pe"],
    "PRODUCCION":    ["jmestanza@cssa.com.pe", "eterrones@cssa.com.pe", "mlopez@cssa.com.pe",
                      "aurcia@cssa.com.pe", "jacosta@cssa.com.pe", "jvargasb@cssa.com.pe", "jcastilloj@cssa.com.pe"],
    "SMA":           ["evasquezp@cssa.com.pe", "mvillagarcia@cssa.com.pe", "esuxe@cssa.com.pe"]
  };

  // Normalizar imagenesUrls a array
  let listaUrls = [];
  if (Array.isArray(imagenesUrls)) {
    listaUrls = imagenesUrls.filter(u => u && u.toString().trim().length > 10);
  } else if (typeof imagenesUrls === "string" && imagenesUrls.trim().length > 10) {
    listaUrls = imagenesUrls.split("|").map(u => u.trim()).filter(u => u.length > 10);
  }

  // Obtener correos adicionales desde la tabla de soporte
  const correosAdicionales = obtenerCorreosAdicionalesPorResponsable(responsable.nombre || "");

  let destinatarios = [];
  if (to && to.includes("@")) destinatarios.push(to);

  let listaCC = [...copiaSMA];
  if (responsable.area && equiposPorArea[responsable.area]) {
    listaCC = listaCC.concat(equiposPorArea[responsable.area]);
  }
  if (correosAdicionales.length > 0) {
    listaCC = listaCC.concat(correosAdicionales);
