          </p>
        </div>

        <hr style="border:none;border-top:1px solid #eee;margin:20px 0;">
        <p style="font-size:12px;color:#888;margin:0;">
          Saludos,<br>
          <b>Mauricio Villa Garcia Nunez</b><br>
          Inspector SMA - Cementos Pacasmayo
        </p>
      </div>
    </div>`;

  if (!to || !to.includes("@")) {
    Logger.log("Correo no enviado: destinatario invalido -> " + to);
    return;
  }

  const opciones = {
    cc:       ccFinal.join(","),
    htmlBody: cuerpoHtml
