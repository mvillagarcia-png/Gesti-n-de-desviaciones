// ==========================================
// PROCESAMIENTO Y REGISTRO
// ==========================================

function registrarFormulario(formData, base64) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const hoja = ss.getSheetByName("Acumulado");
  if (!hoja) throw new Error("No se encontró la hoja 'Acumulado'");

  const fila = [];

  // --- Manejo de Fechas (Normalización Perú) ---
  const procesarFecha = (str) => {
    if (!str) return null;
    let d = str.includes("/") ?
      new Date(str.split("/")[2], str.split("/")[1] - 1, str.split("/")[0]) : new Date(str);
    d.setHours(0, 0, 0, 0);
    return d;
  };

  const fechaEvento = procesarFecha(formData.fecha);
  const fechaLimite = procesarFecha(formData.fechaLimite);

  // --- Generación de Ítem y Código ---
  const anio = fechaEvento.getFullYear();
  const ultimaFilaDatos = hoja.getLastRow();
  let item = 1;
  if (ultimaFilaDatos > 1) {
    const ultimoValorItem = hoja.getRange(ultimaFilaDatos, 1).getValue();
    if (!isNaN(ultimoValorItem)) item = Number(ultimoValorItem) + 1;
  }
  const codigo = `${anio}-${String(item).padStart(3, "0")}`;

  // --- Obtención Dinámica de Responsable ---
  const responsablesDB = mapearResponsablesDesdeTabla3();
  const datosResp = responsablesDB[formData.responsable.trim()] || ["", "S/D", "S/D", ""];
  Logger.log("Responsable recibido del formulario: '" + formData.responsable + "'");
  Logger.log("Datos encontrados: " + JSON.stringify(datosResp));

  const emailResp = datosResp[0];
  const subArea   = datosResp[1];
  const area      = datosResp[2];

  // --- Mapeo de Columnas A..AQ ---
  fila[0]  = item;
  fila[1]  = anio;
  fila[2]  = codigo;
  fila[3]  = fechaEvento;
  fila[4]  = fechaEvento.getMonth() + 1;
  fila[5]  = fechaEvento.toLocaleString("es-PE", { month: "long" }).toUpperCase();
  fila[6]  = fechaEvento.toLocaleString("es-PE", { month: "short" }).toUpperCase();
  fila[7]  = "Q" + (Math.floor(fechaEvento.getMonth() / 3) + 1);
  fila[8]  = (fechaEvento.getMonth() + 1) + "." + fila[6];
  fila[9]  = 1;
  fila[10] = formData.unidad;
  fila[11] = formData.aspecto;
  fila[12] = formData.claseEvento;
  fila[13] = formData.severidadEvento;
  fila[14] = formData.diasPerdidos || "";
  fila[15] = formData.empresa;
  fila[16] = formData.empresa === "CSSA" ? "PROPIO" : "TERCERO";
  fila[17] = formData.area;
  fila[18] = formData.lugar;
  fila[19] = formData.tipificacion;
  fila[20] = formData.desglose1;
  fila[21] = formData.desglose2 || "";
  fila[22] = formData.detalle;
  fila[23] = formData.actoCondicion;
  fila[24] = parseInt(formData.probabilidad);
  fila[25] = parseInt(formData.severidadTexto);
  fila[26] = fila[24] * fila[25];
  fila[27] = formData.criticidad;
  fila[28] = formData.nombreRelacion1;
  fila[29] = formData.nombreRelacion2;
  fila[30] = formData.causasInmediatas;
  fila[31] = formData.causasBasicas;
  fila[32] = formData.accionCorrectiva;
  fila[33] = formData.accionPreventiva;
  fila[34] = formData.responsable;
  fila[35] = emailResp;
  fila[36] = area;
  fila[37] = fechaLimite;
  fila[38] = formData.status;
  fila[39] = "";  // ESTATUS FINAL — se llena con fórmula
  fila[40] = formData.quienReporta;       // AO — ¿Quién realizó el reporte?
  fila[41] = formData.nombreReportante;   // AP — Nombre reportante
  fila[42] = verificarProgramado(formData.quienReporta); // AQ — Programado
  fila[43] = formData.areaReportante;     // AR
  fila[44] = subArea;                     // AS

  if (fechaLimite) {
    fila[45] = fechaLimite.toLocaleString("es-PE", { month: "long" }).toUpperCase();
    fila[46] = fechaLimite.getMonth() + 1;
    fila[47] = fechaLimite.getFullYear();
    fila[48] = "Q" + (Math.floor(fechaLimite.getMonth() / 3) + 1);
  }

  // --- Escritura y Fórmulas ---
  hoja.appendRow(fila);
  const uF = hoja.getLastRow();

  hoja.getRange(uF, 40).setFormula(
    `=IF(AM${uF}="Ejecutado","Ejecutado",IF(AL${uF}="","",IF(AL${uF}<TODAY(),"Pendiente","En Plazo")))`
  );

  // --- Multimedia y Notificación ---
  let listaUrls = [];

  if (base64) {
    const urlNueva = guardarImagenEnCelda(base64, uF, codigo);
    if (urlNueva) listaUrls.push(urlNueva);
  } else if (formData._imgUrlExistente) {
    const rawUrls = formData._imgUrlExistente.toString().trim();
    listaUrls = rawUrls
      .split("|")
      .map(u => u.trim())
      .filter(u => u.length > 10);

    if (listaUrls.length > 0) {
      hoja.getRange("AX" + uF).setFormula(`=HYPERLINK("${listaUrls[0]}", "ver imagen")`);
      hoja.getRange("AY" + uF).setValue(listaUrls.join(" | "));
    }
  }

  // Enviar correo con TODAS las URLs
  enviarCorreo(
    {
      nombre:  formData.responsable,
      subArea: subArea,
      area:    area
    },
    emailResp,
    codigo,
    formData.detalle,
    listaUrls,
    formData.fechaLimite,
    formData.criticidad
  );

  return "✅ ITEM " + codigo + " registrado con éxito.";
}


