  <script>
    var base64FotoInspector = "";
    var reportes            = [];
    var reporteActivo       = null;
    var filtroActivo        = "todos";
    var evidenciasCache     = [];
    var evRechazoFilaLev    = null;
    var evRechazoCodigo     = null;

    function showToast(msg, tipo) {
      tipo = tipo || "ok";
      var t = document.getElementById("toast");
      t.textContent = msg;
      t.className = "toast " + tipo;
      t.classList.add("show");
      setTimeout(function(){ t.classList.remove("show"); }, 3500);
    }

    function ocultarTodo() {
      var ids = ["vista-cargando","vista-bandeja","vista-validacion","vista-exito","vista-anulado","vista-evidencias","vista-kpi"];
      for (var i = 0; i < ids.length; i++) {
        document.getElementById(ids[i]).style.display = "none";
      }
    }

    function cambiarVistaPrincipal(vista) {
      document.querySelectorAll(".nav-tab").forEach(function(t){ t.classList.remove("active"); });
      ocultarTodo();
      if (vista === "bandeja") {
        document.getElementById("tab-bandeja").classList.add("active");
        document.getElementById("vista-bandeja").style.display = "block";
        renderTabla(filtroActivo);
      } else if (vista === "evidencias") {
        document.getElementById("tab-evidencias").classList.add("active");
        document.getElementById("vista-evidencias").style.display = "block";
        cargarEvidencias();
      } else if (vista === "kpi") {
        document.getElementById("tab-kpi").classList.add("active");
        document.getElementById("vista-kpi").style.display = "block";
      }
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function cargarBandeja() {
      ocultarTodo();
      document.getElementById("vista-cargando").style.display = "flex";
      google.script.run
        .withSuccessHandler(function(data) {
          reportes = data || [];
          ocultarTodo();
          document.getElementById("vista-bandeja").style.display = "block";
          document.getElementById("tab-bandeja").classList.add("active");
          renderTabla(filtroActivo);
        })
        .withFailureHandler(function(e) {
          ocultarTodo();
          document.getElementById("vista-bandeja").style.display = "block";
          showToast("Error al cargar: " + e.message, "error");
        })
        .obtenerReportesBandeja();
    }

    function cargarBandejaBackground() {
      google.script.run
        .withSuccessHandler(function(data){ reportes = data || []; })
        .obtenerReportesBandeja();
    }

    function renderTabla(filtro) {
      var tbody = document.getElementById("tabla-body");
      var lista = filtro === "todos" ? reportes : reportes.filter(function(r){ return r.estado === filtro; });
      if (lista.length === 0) {
        tbody.innerHTML = '<div class="empty-state"><div class="empty-icon">📭</div><div class="empty-text">No hay reportes</div></div>';
        return;
      }
      var html = "";
      for (var i = 0; i < lista.length; i++) {
        var r = lista[i];
        var cls = r.estado === "PENDIENTE" ? "pendiente" : "atendido";
        var badge = r.estado === "PENDIENTE"
          ? '<span class="estado-badge pendiente">⏳ Pendiente</span>'
          : '<span class="estado-badge atendido">✅ Atendido</span>';
        var btn = r.estado === "PENDIENTE"
          ? '<button class="btn-atender" onclick="abrirValidacion(' + r.id + ')">Atender →</button>'
          : '<button class="btn-ver" onclick="abrirValidacion(' + r.id + ')">Ver</button>';
        html += '<div class="tabla-fila ' + cls + '" data-id="' + r.id + '">';
        html += '<div class="col-codigo">' + (r.codigoRef || "—") + '</div>';
        html += '<div><div class="col-trabajador">' + (r.nombre || "—") + '</div><div class="col-area">' + (r.empresa || "—") + '</div></div>';
        html += '<div class="col-desc">' + (r.descripcion || "—") + '</div>';
        html += '<div class="col-fecha">' + (r.fechaEvento || "—") + '</div>';
        html += '<div>' + badge + '</div><div>' + btn + '</div></div>';
      }
      tbody.innerHTML = html;
    }

    function abrirValidacion(id) {
      reporteActivo = null;
      for (var i = 0; i < reportes.length; i++) {
        if (String(reportes[i].id) === String(id)) { reporteActivo = reportes[i]; break; }
      }
      if (!reporteActivo) { showToast("No se encontró el reporte", "error"); return; }
      ocultarTodo();
      document.getElementById("vista-validacion").style.display = "block";
      document.getElementById("d-nombre").textContent       = reporteActivo.nombre      || "—";
      document.getElementById("d-apellidos").textContent    = reporteActivo.apellidos   || "—";
      var cel = String(reporteActivo.celular || "");
      document.getElementById("d-celular").textContent = cel || "—";
      var waBtn = document.getElementById("d-celular-wa");
      if (cel) { waBtn.href = "https://wa.me/51" + cel.replace(/\s/g,"").replace(/^\+51/,""); waBtn.style.display = "inline-block"; }
      else { waBtn.style.display = "none"; }
      document.getElementById("d-empresa").textContent      = reporteActivo.empresa     || "—";
      if (reporteActivo.correo) { document.getElementById("d-correo").textContent = reporteActivo.correo; document.getElementById("d-correo-item").style.display = "block"; }
      else { document.getElementById("d-correo-item").style.display = "none"; }
      document.getElementById("d-fecha").textContent        = reporteActivo.fechaEvento || "—";
      document.getElementById("d-lugar").textContent        = reporteActivo.lugar       || "—";
      document.getElementById("d-fechaReporte").textContent = reporteActivo.fechaReporte|| "—";
      document.getElementById("d-descripcion").textContent  = reporteActivo.descripcion || "—";
      if (reporteActivo.propuesta) { document.getElementById("d-propuesta").textContent = reporteActivo.propuesta; document.getElementById("d-propuesta-item").style.display = "block"; }
      else { document.getElementById("d-propuesta-item").style.display = "none"; }
      document.getElementById("panelCodigo").textContent    = reporteActivo.codigoRef   || "—";
      base64FotoInspector = "";
      var imgEl   = document.getElementById("d-imagen");
      var urlsRaw = String(reporteActivo.imgUrl || "").trim();
      var listaUrls = urlsRaw.split("|").map(function(u){ return u.trim(); }).filter(function(u){ return u.length > 10; });
      if (listaUrls.length > 0) {
        var imgHtml = "";
        for (var j = 0; j < listaUrls.length; j++) {
          var url = listaUrls[j];
          var esVid = /\.(mp4|mov|avi)/i.test(url);
          var icono = esVid ? "🎬" : "📷";
          var etiq  = esVid ? "Ver video" : "Ver imagen";
          var num   = listaUrls.length > 1 ? " " + (j + 1) : "";
          imgHtml += '<a href="' + url + '" target="_blank" class="btn-ver-img" style="margin-right:6px;margin-bottom:6px;display:inline-flex;">' + icono + ' ' + etiq + num + ' →</a>';
        }
        imgEl.innerHTML = imgHtml;
      } else {
        imgEl.innerHTML = '<div id="foto-inspector-wrap"><label style="cursor:pointer;display:inline-block;"><input type="file" id="fotoInspectorInput" accept="image/*" style="display:none;" /><span class="btn-adjuntar-foto">📎 Adjuntar foto</span></label><div id="foto-inspector-preview" style="display:none;margin-top:8px;"><img id="foto-inspector-img" src="" style="max-width:100%;border-radius:4px;border:1px solid #e5e7eb;" /><button type="button" id="foto-inspector-remove" style="margin-top:4px;background:none;border:none;color:#CE000C;font-size:12px;cursor:pointer;font-weight:600;">✕ Quitar foto</button></div></div>';
        setTimeout(function(){
          var inp = document.getElementById("fotoInspectorInput");
          if (inp) inp.addEventListener("change", function(e){
            var file = e.target.files[0]; if (!file) return;
            comprimirImagenInspector(file, function(b64){ base64FotoInspector = b64; document.getElementById("foto-inspector-img").src = b64; document.getElementById("foto-inspector-preview").style.display = "block"; });
          });
          var btnR = document.getElementById("foto-inspector-remove");
          if (btnR) btnR.addEventListener("click", function(){ base64FotoInspector = ""; document.getElementById("fotoInspectorInput").value = ""; document.getElementById("foto-inspector-preview").style.display = "none"; document.getElementById("foto-inspector-img").src = ""; });
        }, 100);
      }
      try { document.getElementById("formInspector").reset(); } catch(e){}
      document.getElementById("detalle").value = reporteActivo.descripcion || "";
      calcularRiesgo();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function comprimirImagenInspector(file, callback) {
      var reader = new FileReader();
      reader.onload = function(ev) {
        var img = new Image();
        img.onload = function() {
          var MAX = 1280, w = img.width, h = img.height;
          if (w > MAX || h > MAX) { if (w > h) { h = Math.round(h*MAX/w); w = MAX; } else { w = Math.round(w*MAX/h); h = MAX; } }
          var canvas = document.createElement("canvas"); canvas.width = w; canvas.height = h;
          canvas.getContext("2d").drawImage(img, 0, 0, w, h);
          callback(canvas.toDataURL("image/jpeg", 0.75));
        };
        img.src = ev.target.result;
      };
      reader.readAsDataURL(file);
    }

    function calcularRiesgo() {
      var p = parseInt(document.getElementById("probabilidad").value) || 0;
      var s = parseInt(document.getElementById("severidadTexto").value) || 0;
      var display = document.getElementById("riesgoDisplay");
      if (!p || !s) { display.textContent = "—"; display.className = "riesgo-display"; return; }
      var r = p * s; display.textContent = r;
      if (r <= 8) display.className = "riesgo-display bajo";
      else if (r <= 15) display.className = "riesgo-display medio";
      else display.className = "riesgo-display alto";
    }
    document.getElementById("probabilidad").addEventListener("input", calcularRiesgo);
    document.getElementById("severidadTexto").addEventListener("input", calcularRiesgo);

    document.getElementById("formInspector").addEventListener("submit", function(e) {
      e.preventDefault();
      var btn = document.getElementById("btnValidar"); var btnText = document.getElementById("btnValidarText"); var spinner = document.getElementById("spinnerVal");
      btn.disabled = true; btnText.textContent = "Registrando..."; spinner.style.display = "block";
      var datosInspector = {
        aspecto: document.getElementById("aspecto").value, claseEvento: document.getElementById("claseEvento").value,
        unidad: document.getElementById("unidad").value, empresa: document.getElementById("empresa").value,
        tipificacion: document.getElementById("tipificacion").value, desglose1: document.getElementById("desglose1").value.trim(),
        actoCondicion: document.getElementById("actoCondicion").value, probabilidad: document.getElementById("probabilidad").value,
        severidadTexto: document.getElementById("severidadTexto").value, criticidad: document.getElementById("criticidad").value,
        diasPerdidos: document.getElementById("diasPerdidos").value, nombreRelacion1: document.getElementById("nombreRelacion1").value.trim(),
        nombreRelacion2: document.getElementById("nombreRelacion2").value.trim(), accionCorrectiva: document.getElementById("accionCorrectiva").value.trim(),
        accionPreventiva: document.getElementById("accionPreventiva").value.trim(), responsable: document.getElementById("responsable").value,
        fechaLimite: document.getElementById("fechaLimite").value, status: document.getElementById("status").value,
        fecha: reporteActivo.fechaEvento, lugar: reporteActivo.lugar, detalle: document.getElementById("detalle").value.trim(),
        quienReporta: document.getElementById("quienReporta").value, nombreReportante: document.getElementById("nombreReportante").value.trim(),
        areaReportante: document.getElementById("areaReportante").value.trim(), desglose2: ""
      };
      google.script.run
        .withSuccessHandler(function(codigo) {
          document.getElementById("exitoCodigo").textContent = codigo;
          ocultarTodo(); document.getElementById("vista-exito").style.display = "flex";
          cargarBandejaBackground();
        })
        .withFailureHandler(function(err) {
          showToast("Error: " + err.message, "error");
          btn.disabled = false; btnText.textContent = "✅ Registrar en Acumulado"; spinner.style.display = "none";
        })
        .validarYPasarAcumulado(reporteActivo.id, reporteActivo.codigoRef, datosInspector, base64FotoInspector);
    });

    document.querySelectorAll(".filtro-btn").forEach(function(btn){
      btn.addEventListener("click", function(){
        document.querySelectorAll(".filtro-btn").forEach(function(b){ b.classList.remove("active"); });
        this.classList.add("active"); filtroActivo = this.dataset.filtro; renderTabla(filtroActivo);
      });
    });

    document.getElementById("btnBack").addEventListener("click", function(){ cambiarVistaPrincipal("bandeja"); });
    document.getElementById("btnVolverBandeja").addEventListener("click", function(){
      document.getElementById("formInspector").reset(); $(".select-buscable").val("").trigger("change");
      base64FotoInspector = ""; document.getElementById("btnValidar").disabled = false;
      document.getElementById("btnValidarText").textContent = "✅ Registrar en Acumulado";
      document.getElementById("spinnerVal").style.display = "none"; reporteActivo = null;
      cambiarVistaPrincipal("bandeja");
    });
    document.getElementById("btnVolverBandejaAnulado").addEventListener("click", function(){ reporteActivo = null; cambiarVistaPrincipal("bandeja"); });
    document.getElementById("btnAnular").addEventListener("click", function(){ document.getElementById("motivoAnulacion").value = ""; document.getElementById("modalAnular").style.display = "flex"; });
    document.getElementById("btnCancelarAnular").addEventListener("click", function(){ document.getElementById("modalAnular").style.display = "none"; });
    document.getElementById("btnConfirmarAnular").addEventListener("click", function(){
      var motivo = document.getElementById("motivoAnulacion").value.trim();
      if (!motivo) { document.getElementById("motivoAnulacion").style.borderColor = "#c0392b"; return; }
      document.getElementById("motivoAnulacion").style.borderColor = "";
      var btnConf = document.getElementById("btnConfirmarAnular"); var btnText = document.getElementById("btnAnularText"); var spinner = document.getElementById("spinnerAnular");
      btnConf.disabled = true; btnText.textContent = "Anulando..."; spinner.style.display = "block";
      google.script.run
        .withSuccessHandler(function(){
          document.getElementById("modalAnular").style.display = "none";
          document.getElementById("btnValidar").disabled = false;
          document.getElementById("btnValidarText").textContent = "✅ Registrar en Acumulado";
          document.getElementById("spinnerVal").style.display = "none";
          ocultarTodo(); document.getElementById("vista-anulado").style.display = "flex"; cargarBandejaBackground();
        })
        .withFailureHandler(function(err){
          showToast("Error al anular: " + err.message, "error");
          btnConf.disabled = false; btnText.textContent = "Confirmar anulación"; spinner.style.display = "none";
        })
        .anularReporte(reporteActivo.id, reporteActivo.correo, reporteActivo.nombre, motivo);
    });

    // ══════════════════════════════════════════════════
    // EVIDENCIAS
    // ══════════════════════════════════════════════════
    function cargarEvidencias() {
      var cont = document.getElementById("ev-contenido");
      cont.innerHTML = '<div class="ev-empty">⏳ Cargando evidencias pendientes...</div>';
      google.script.run
        .withSuccessHandler(function(lista){
          evidenciasCache = lista || [];
          renderEvidencias(evidenciasCache);
          actualizarBadgeEvidencias(evidenciasCache.length);
        })
        .withFailureHandler(function(err){
          cont.innerHTML = '<div class="ev-empty" style="color:#CE000C;">❌ Error al cargar: ' + err.message + '</div>';
        })
        .obtenerLevantamientosPendientes();
    }

    function actualizarBadgeEvidencias(n) {
      var badge = document.getElementById("badge-ev");
      if (n > 0) { badge.textContent = n; badge.style.display = "inline-block"; }
      else { badge.style.display = "none"; }
    }

    function esVideo(url) { var u = (url || "").toLowerCase(); return u.includes(".mp4") || u.includes(".mov") || u.includes(".avi") || u.includes(".webm"); }

    function extraerFileIdDrive(url) {
      if (!url) return null;
      var m = url.match(/\/file\/d\/([a-zA-Z0-9_-]{20,})/); if (m) return m[1];
      m = url.match(/[?&]id=([a-zA-Z0-9_-]{20,})/); if (m) return m[1];
      m = url.match(/([a-zA-Z0-9_-]{25,})/); return m ? m[1] : null;
    }

    function buildThumbHtml(url, idx) {
      var fileId = extraerFileIdDrive(url); var esVid = esVideo(url);
      if (!fileId) return '<a href="' + url + '" target="_blank" class="ev-archivo-link">📎 Archivo ' + (idx + 1) + ' →</a>';
      var thumbUrl = "https://drive.google.com/thumbnail?id=" + fileId + "&sz=w300";
      var overlay  = esVid ? '<div class="ev-thumb-overlay-video"><div class="ev-thumb-play">▶</div></div>' : "";
      var tipoLabel = esVid ? "🎬 Video" : "🖼️ Foto"; var fallbackIcon = esVid ? "🎬" : "🖼️";
      return '<a href="' + url + '" target="_blank" class="ev-thumb">'
        + '<div class="ev-thumb-box"><img src="' + thumbUrl + '" alt="evidencia ' + (idx+1) + '" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';" />'
        + '<div class="ev-thumb-fallback">' + fallbackIcon + '</div>' + overlay + '</div>'
        + '<div class="ev-thumb-label">' + tipoLabel + ' ' + (idx + 1) + '</div></a>';
    }

    // ── Render evidencias con bloque de desviación original completo ──
    function renderEvidencias(lista) {
      var cont = document.getElementById("ev-contenido");
      if (!lista || lista.length === 0) {
        cont.innerHTML = '<div class="ev-empty"><div style="font-size:48px;margin-bottom:12px;">✅</div><div style="font-weight:600;color:var(--ink-soft);margin-bottom:4px;">Todo al día</div><div>No hay evidencias pendientes de validación</div></div>';
        return;
      }
      var html = "";
      for (var i = 0; i < lista.length; i++) {
        var ev = lista[i];

        // Thumbnails
        var thumbsHtml = "";
        for (var j = 0; j < ev.urls.length; j++) thumbsHtml += buildThumbHtml(ev.urls[j], j);

        // Bloque desviación original — se construye si hay datos
        var bloqueOriginal = "";
        if (ev.detalleObservacion || ev.responsable || ev.area || ev.fechaLimite || ev.criticidad) {
          bloqueOriginal += '<div class="ev-desviacion-original">';
          bloqueOriginal += '<div class="ev-desviacion-original-title">🔍 Desviación Original — ' + ev.codigo + '</div>';
          bloqueOriginal += '<div class="ev-desviacion-grid">';

          if (ev.area) {
            bloqueOriginal += '<div class="ev-dato"><div class="ev-dato-label">Área</div><div class="ev-dato-valor">' + ev.area + '</div></div>';
          }
          if (ev.responsable) {
            bloqueOriginal += '<div class="ev-dato"><div class="ev-dato-label">Responsable</div><div class="ev-dato-valor">' + ev.responsable + '</div></div>';
          }
          if (ev.aspecto) {
            bloqueOriginal += '<div class="ev-dato"><div class="ev-dato-label">Aspecto</div><div class="ev-dato-valor">' + ev.aspecto + '</div></div>';
          }
          if (ev.clase) {
            bloqueOriginal += '<div class="ev-dato"><div class="ev-dato-label">Clase</div><div class="ev-dato-valor">' + ev.clase + '</div></div>';
          }
          if (ev.criticidad) {
            bloqueOriginal += '<div class="ev-dato"><div class="ev-dato-label">Criticidad</div><div class="ev-dato-valor">' + ev.criticidad + '</div></div>';
          }
          if (ev.fechaLimite) {
            bloqueOriginal += '<div class="ev-dato"><div class="ev-dato-label">Fecha Límite</div><div class="ev-dato-valor">' + ev.fechaLimite + '</div></div>';
          }
          if (ev.accionCorrectiva) {
            bloqueOriginal += '<div class="ev-dato span-2"><div class="ev-dato-label">Acción Correctiva Indicada</div><div class="ev-dato-valor">' + ev.accionCorrectiva + '</div></div>';
          }
          bloqueOriginal += '</div>'; // cierra grid

          if (ev.detalleObservacion) {
            bloqueOriginal += '<div class="ev-dato-label" style="margin-top:10px;color:#9a3412;">Detalle de la Desviación</div>';
            bloqueOriginal += '<div class="ev-detalle-box">' + ev.detalleObservacion + '</div>';
          }
          bloqueOriginal += '</div>'; // cierra ev-desviacion-original
        }

        // Acciones tomadas por el área
        var accionesHtml = '<div class="ev-desc"><strong style="color:#16a34a;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:6px;">✅ Acciones tomadas por el área:</strong>' + ev.descripcion + '</div>';

        html += '<div class="ev-card" id="ev-card-' + ev.filaLev + '">';
        html += '<div class="ev-header"><div class="ev-codigo">📋 ' + ev.codigo + '</div><div class="ev-badge-pend">⏳ PENDIENTE</div></div>';
        html += '<div class="ev-body">';
        html += '<div class="ev-meta"><strong>👤 ' + ev.nombre + '</strong> &nbsp;·&nbsp; 📅 ' + ev.fechaEnvio + ' &nbsp;·&nbsp; 📎 ' + ev.numArchivos + ' archivo(s)</div>';
        html += bloqueOriginal;
        html += accionesHtml;
        html += '<div class="ev-thumbs-wrap">' + thumbsHtml + '</div>';
        html += '<div class="ev-acciones">';
        html += '<button class="btn-aceptar-ev" onclick="aceptarEvidencia(\'' + ev.codigo + '\', ' + ev.filaLev + ')">✅ Aceptar y marcar como Ejecutado</button>';
        html += '<button class="btn-rechazar-ev" onclick="abrirModalRechazo(\'' + ev.codigo + '\', ' + ev.filaLev + ')">🚫 Rechazar</button>';
        html += '</div></div></div>';
      }
      cont.innerHTML = html;
    }

    function aceptarEvidencia(codigo, filaLev) {
      if (!confirm("¿Aceptar la evidencia de " + codigo + "?\n\nLa desviación pasará a estatus EJECUTADO.")) return;
      var card = document.getElementById("ev-card-" + filaLev);
      if (card) { card.style.opacity = "0.5"; card.style.pointerEvents = "none"; }
      google.script.run
        .withSuccessHandler(function(){
          showToast("✅ " + codigo + " aceptado · Estatus → Ejecutado", "ok");
          evidenciasCache = evidenciasCache.filter(function(ev){ return ev.filaLev !== filaLev; });
          renderEvidencias(evidenciasCache); actualizarBadgeEvidencias(evidenciasCache.length);
        })
        .withFailureHandler(function(err){
          showToast("Error al aceptar: " + err.message, "error");
          if (card) { card.style.opacity = "1"; card.style.pointerEvents = "auto"; }
        })
        .aceptarLevantamiento(codigo, filaLev, "Inspector SMA");
    }

    function abrirModalRechazo(codigo, filaLev) {
      evRechazoCodigo = codigo; evRechazoFilaLev = filaLev;
      document.getElementById("motivo-rechazo").value = "";
      document.getElementById("modal-rechazo").classList.add("show");
      setTimeout(function(){ document.getElementById("motivo-rechazo").focus(); }, 100);
    }

    function cerrarModalRechazo() {
      document.getElementById("modal-rechazo").classList.remove("show");
      evRechazoCodigo = null; evRechazoFilaLev = null;
    }

    function confirmarRechazo() {
      var motivo = document.getElementById("motivo-rechazo").value.trim();
      if (!motivo || motivo.length < 10) { showToast("Ingresa un motivo de al menos 10 caracteres", "error"); return; }
      var codigo = evRechazoCodigo; var filaLev = evRechazoFilaLev;
      var card = document.getElementById("ev-card-" + filaLev);
      if (card) { card.style.opacity = "0.5"; card.style.pointerEvents = "none"; }
      cerrarModalRechazo();
      google.script.run
        .withSuccessHandler(function(){
          showToast("🚫 " + codigo + " rechazado · Correo enviado", "ok");
          evidenciasCache = evidenciasCache.filter(function(ev){ return ev.filaLev !== filaLev; });
          renderEvidencias(evidenciasCache); actualizarBadgeEvidencias(evidenciasCache.length);
        })
        .withFailureHandler(function(err){
          showToast("Error al rechazar: " + err.message, "error");
          if (card) { card.style.opacity = "1"; card.style.pointerEvents = "auto"; }
        })
        .rechazarLevantamiento(codigo, filaLev, "Inspector SMA", motivo);
    }

    document.getElementById("modal-rechazo").addEventListener("click", function(e){ if (e.target === this) cerrarModalRechazo(); });

    function cargarKpi() {
      document.getElementById("kpi-contenido").innerHTML = '<div class="kpi-empty">📊 Sección KPI en desarrollo</div>';
    }

    document.addEventListener("DOMContentLoaded", function(){
      $(".select-buscable").select2({ width: "100%", placeholder: "— Escribe para buscar —", allowClear: true });
      cargarBandeja();
      setTimeout(function(){
        google.script.run
          .withSuccessHandler(function(lista){ actualizarBadgeEvidencias((lista || []).length); })
          .withFailureHandler(function(){})
          .obtenerLevantamientosPendientes();
      }, 1500);
    });
  </script>
