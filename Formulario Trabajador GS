// ============================================================
// 1. SERVICIO WEB (doGet) — UNIFICADO
// ============================================================

function doGet(e) {
  const cual = e && e.parameter && e.parameter.form;

  if (cual === "trabajador") {
    const template = HtmlService.createTemplateFromFile("Formulario Trabajador Html");
    template.nombres                = obtenerNombresCompletos();
    template.nombresPersonal        = obtenerNombresPersonal();
    template.desviacionesPendientes = obtenerDesviacionesPendientesLev();
    return template.evaluate()
      .setTitle("Portal SMA · CSSA")
      .addMetaTag("viewport", "width=device-width, initial-scale=1");

  } else if (cual === "inspector") {
    const template = HtmlService.createTemplateFromFile("Panel Inspector Html");
    template.empresas          = obtenerEmpresas();
    template.tipificaciones    = obtenerTipificaciones();
    template.responsables      = obtenerResponsables();
    template.subAreas          = obtenerSubAreas();
    template.nombresPersonal   = obtenerNombresPersonal();
    template.quienReportaOpts  = obtenerQuienReporta();
    return template.evaluate()
      .setTitle("Panel Inspector · CSSA")
      .addMetaTag("viewport", "width=device-width, initial-scale=1");

  } else if (cual === "inspeccion") {
    const template = HtmlService.createTemplateFromFile("Formulario Inspeccion Html");
    template.responsables = obtenerResponsables();
    return template.evaluate()
      .setTitle("Inspección SMA · Cementos Pacasmayo")
      .addMetaTag("viewport", "width=device-width, initial-scale=1");

  } else {
    const template = HtmlService.createTemplateFromFile("Formulario Evento Html");
    template.nombres        = obtenerNombresCompletos();
    template.empresas       = obtenerEmpresas();
    template.tipificaciones = obtenerTipificaciones();
    template.responsables   = obtenerResponsables();
    return template.evaluate()
      .setTitle("Formulario de Eventos")
      .addMetaTag("viewport", "width=device-width, initial-scale=1");
  }
}

// ============================================================
// 2. REGISTRO EN BANDEJA DE ENTRADA
// ============================================================

function registrarReporteTrabajador(data, archivos) {

  const ss   = SpreadsheetApp.getActiveSpreadsheet();
  let hoja   = ss.getSheetByName("Bandeja de Entrada");

  if (!hoja) {
    hoja = ss.insertSheet("Bandeja de Entrada");
    hoja.appendRow([
      "ID", "FECHA REPORTE", "CÓDIGO REF", "NOMBRE TRABAJADOR",
      "APELLIDOS", "CELULAR", "CORREO", "EMPRESA", "FECHA EVENTO", "LUGAR", "DESCRIPCIÓN",
      "ARCHIVOS URLS", "PROPUESTA", "ESTADO"
    ]);
    hoja.getRange(1, 1, 1, 14)
      .setBackground("#1c2b3a")
      .setFontColor("#f0a500")
      .setFontWeight("bold");
    hoja.setFrozenRows(1);
  }

  const ahora      = new Date();
  const ultimaFila = hoja.getLastRow();
  const id         = ultimaFila;

  let fechaEvento = null;
  if (data.fecha) {
    const partes = data.fecha.split("-");
    fechaEvento  = new Date(partes[0], partes[1] - 1, partes[2]);
  }

  const listaUrls = guardarArchivosReporteTrabajador(archivos, "RPT-" + id);
  const urlsStr   = listaUrls.join(" | ");

  hoja.appendRow([
    id,
    ahora,
    "",
    data.nombre,
    data.apellidos || "",
    data.celular   || "",
    data.correo    || "",
    data.empresa   || "",
    fechaEvento,
    data.lugar,
    data.descripcion,
    urlsStr,
    data.propuesta || "",
    "PENDIENTE",
  ]);

  const uF = hoja.getLastRow();
  hoja.getRange(uF, 2).setNumberFormat("dd/MM/yyyy HH:mm");
  hoja.getRange(uF, 9).setNumberFormat("dd/MM/yyyy");
  hoja.getRange(uF, 1, 1, 14).setBackground("#fff9e6");

  enviarAlertaInspector(data, listaUrls, ahora);

  Logger.log("✅ Reporte trabajador guardado. Archivos: " + listaUrls.length + " | ID: " + id);
  return "PENDIENTE";
}

// ============================================================
// 3. CORREO DE ALERTA AL INSPECTOR
// ============================================================

function enviarAlertaInspector(data, listaUrls, fechaReporte) {

  const DESTINATARIOS = "mvillagarcia@cssa.com.pe,evasquezp@cssa.com.pe,esuxe@cssa.com.pe";
  const tz            = Session.getScriptTimeZone();
  const fechaStr      = Utilities.formatDate(fechaReporte, tz, "dd/MM/yyyy 'a las' HH:mm");
  const asunto        = "🔔 Nuevo reporte SMA · " + data.nombre + " · " + fechaStr;
  const urlPanel      = ScriptApp.getService().getUrl() + "?form=inspector";

  let filasEvidencia = "";
  if (listaUrls.length > 0) {
    listaUrls.forEach(function(url, i) {
      const esVideo = /\.(mp4|mov|avi)/i.test(url);
      const icono   = esVideo ? "🎬" : "📷";
      const etiq    = esVideo ? "Ver video" : "Ver imagen";
      const num     = listaUrls.length > 1 ? " " + (i + 1) : "";
      const bg      = i % 2 === 0 ? "#f9fafb" : "#fff";
      filasEvidencia +=
        '<tr style="background:' + bg + ';">'
        + '<td style="padding:8px 6px;color:#6b7280;font-weight:600;">' + icono + ' Evidencia' + num + '</td>'
        + '<td style="padding:8px 6px;">'
        + '<a href="' + url + '" target="_blank" style="color:#CE000C;font-weight:600;text-decoration:none;">' + etiq + num + ' →</a>'
        + '</td></tr>';
    });
  } else {
    filasEvidencia =
      '<tr style="background:#f9fafb;">'
      + '<td style="padding:8px 6px;color:#6b7280;font-weight:600;">Evidencia</td>'
      + '<td style="padding:8px 6px;color:#9ca3af;">Sin archivos adjuntos</td>'
      + '</tr>';
  }

  const htmlBody =
    '<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;background:#f5f5f5;padding:20px;">'
    + '<div style="background:white;border-radius:4px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.08);">'
    + '<div style="background:#111111;padding:18px 24px;">'
    + '<span style="color:white;font-weight:700;font-size:17px;">Pacasmayo</span>'
    + '<div style="width:12px;height:12px;background:#CE000C;display:inline-block;margin-left:8px;"></div>'
    + '<span style="color:rgba(255,255,255,0.5);font-size:12px;margin-left:6px;">Seguridad y Medio Ambiente</span>'
    + '</div>'
    + '<div style="background:#CE000C;padding:14px 24px;">'
    + '<div style="color:white;font-size:16px;font-weight:700;">🔔 Nuevo Reporte de Desviación</div>'
    + '<div style="color:rgba(255,255,255,0.8);font-size:12px;margin-top:2px;">Requiere revisión en el Panel Inspector SMA</div>'
    + '</div>'
    + '<div style="padding:24px;">'
    + '<table style="width:100%;border-collapse:collapse;font-size:14px;">'
    + '<tr><td style="padding:8px 0;color:#6b7280;font-weight:600;width:140px;">Reportado por</td><td style="padding:8px 0;color:#111111;font-weight:600;">' + data.nombre + '</td></tr>'
    + '<tr style="background:#f9fafb;"><td style="padding:8px 6px;color:#6b7280;font-weight:600;">Empresa</td><td style="padding:8px 6px;color:#111111;">' + (data.empresa || "—") + '</td></tr>'
    + '<tr><td style="padding:8px 0;color:#6b7280;font-weight:600;">Lugar</td><td style="padding:8px 0;color:#111111;">' + data.lugar + '</td></tr>'
    + '<tr style="background:#f9fafb;"><td style="padding:8px 6px;color:#6b7280;font-weight:600;">Fecha del reporte</td><td style="padding:8px 6px;color:#111111;">' + fechaStr + '</td></tr>'
    + '<tr><td style="padding:8px 0;color:#6b7280;font-weight:600;vertical-align:top;">Descripción</td><td style="padding:8px 0;color:#111111;line-height:1.5;">' + data.descripcion + '</td></tr>'
    + filasEvidencia
    + '</table>'
    + (listaUrls.length > 0 ? '<p style="font-size:12px;color:#6b7280;margin:16px 0 0;">📎 Las imágenes también van adjuntas a este correo.</p>' : '')
    + '<div style="text-align:center;margin-top:24px;">'
    + '<a href="' + urlPanel + '" style="background:#CE000C;color:white;text-decoration:none;padding:12px 28px;border-radius:3px;font-weight:700;font-size:14px;display:inline-block;">→ Abrir Panel Inspector</a>'
