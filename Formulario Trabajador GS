  const opciones = { to: DESTINATARIOS, subject: asunto, htmlBody: htmlBody };
  if (adjuntos.length > 0) opciones.attachments = adjuntos;

  MailApp.sendEmail(opciones);
  Logger.log("📧 Alerta SMA enviada → " + DESTINATARIOS);
}

// ============================================================
// 4. GUARDAR ARCHIVOS EN GOOGLE DRIVE
// ============================================================

function guardarArchivosReporteTrabajador(archivos, codigoRef) {
  const urls = [];
  try {
    const carpetaId = "1bxN0M9JjKgzGMmLCYxWkEBW0ByIQh_0M";
    const carpeta   = DriveApp.getFolderById(carpetaId);

    if (typeof archivos === "string" && archivos.length > 100) {
      const url = guardarArchivoIndividual(carpeta, archivos, codigoRef + "_trabajador.png", "image/png");
      if (url) urls.push(url);
      return urls;
    }

    if (!Array.isArray(archivos) || archivos.length === 0) return urls;

    archivos.forEach(function(archivo, idx) {
      try {
        if (!archivo.base64 || archivo.base64.length < 100) return;
        let mimeType  = "image/jpeg";
        let extension = ".jpg";
        if (archivo.tipo === "video" || (archivo.nombre && archivo.nombre.match(/\.(mp4|mov|avi)$/i))) {
          mimeType = "video/mp4"; extension = ".mp4";
        } else if (archivo.nombre && archivo.nombre.match(/\.png$/i)) {
          mimeType = "image/png"; extension = ".png";
        }
        const nombreArchivo = codigoRef + "_" + (idx + 1) + extension;
        const url = guardarArchivoIndividual(carpeta, archivo.base64, nombreArchivo, mimeType);
        if (url) urls.push(url);
      } catch(errArchivo) {
        Logger.log("⚠️ Error al guardar archivo " + idx + ": " + errArchivo.message);
      }
    });
  } catch(err) {
    Logger.log("⚠️ Error en guardarArchivosReporteTrabajador: " + err.message);
  }
  return urls;
}

function guardarArchivoIndividual(carpeta, base64, nombreArchivo, mimeType) {
  try {
    const contenido = base64.includes(",") ? base64.split(",")[1] : base64;
    const blob    = Utilities.newBlob(Utilities.base64Decode(contenido), mimeType, nombreArchivo);
    const archivo = carpeta.createFile(blob);
    archivo.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
    return archivo.getUrl();
  } catch(err) {
    Logger.log("⚠️ Error al guardar " + nombreArchivo + ": " + err.message);
    return "";
  }
}

// ============================================================
// 5. ALERTA DE REPORTES PENDIENTES (+48H)
// ============================================================

function alertarReportesPendientes() {
  const ss   = SpreadsheetApp.getActiveSpreadsheet();
  const hoja = ss.getSheetByName("Bandeja de Entrada");
  if (!hoja || hoja.getLastRow() < 2) return;

  const INSPECTOR_PRINCIPAL = "mvillagarcia@cssa.com.pe";
  const COPIA               = "evasquezp@cssa.com.pe,esuxe@cssa.com.pe";
  const HORAS_LIMITE        = 48;
  const ahora               = new Date();
  const tz                  = Session.getScriptTimeZone();
  const urlPanel            = ScriptApp.getService().getUrl() + "?form=inspector";

  const datos = hoja.getDataRange().getValues();
  const pendientesVencidos = [];

  for (let i = 1; i < datos.length; i++) {
    const fila   = datos[i];
    const estado = fila[13];
    if (estado !== "PENDIENTE") continue;

    const fechaReporte = fila[1];
    if (!(fechaReporte instanceof Date)) continue;

    const horasTranscurridas = (ahora - fechaReporte) / (1000 * 60 * 60);
    if (horasTranscurridas < HORAS_LIMITE) continue;

    pendientesVencidos.push({
      codigo:      fila[2],
      nombre:      fila[3],
      empresa:     fila[7],
      lugar:       fila[9],
      descripcion: fila[10],
      fechaStr:    Utilities.formatDate(fechaReporte, tz, "dd/MM/yyyy HH:mm"),
      horas:       Math.floor(horasTranscurridas)
    });
  }

  if (pendientesVencidos.length === 0) { Logger.log("✅ Sin reportes pendientes vencidos."); return; }

  const total  = pendientesVencidos.length;
  const asunto = "⚠️ " + total + " reporte" + (total > 1 ? "s" : "") + " pendiente" + (total > 1 ? "s" : "") + " sin atender · CSSA SMA";

  const filasHtml = pendientesVencidos.map(r =>
    '<tr>'
    + '<td style="padding:8px 10px;border-bottom:1px solid #eee;font-weight:600;">' + r.codigo + '</td>'
    + '<td style="padding:8px 10px;border-bottom:1px solid #eee;">' + r.nombre + '</td>'
    + '<td style="padding:8px 10px;border-bottom:1px solid #eee;">' + (r.empresa || "—") + '</td>'
    + '<td style="padding:8px 10px;border-bottom:1px solid #eee;">' + r.lugar + '</td>'
    + '<td style="padding:8px 10px;border-bottom:1px solid #eee;">' + r.fechaStr + '</td>'
    + '<td style="padding:8px 10px;border-bottom:1px solid #eee;color:#e03e3e;font-weight:600;">' + r.horas + 'h</td>'
    + '</tr>'
  ).join("");

  const htmlBody =
    '<div style="font-family:Arial,sans-serif;color:#333;max-width:700px;">'
    + '<div style="background:#1c2b3a;padding:20px;border-bottom:3px solid #e03e3e;">'
    + '<h2 style="color:#e03e3e;margin:0;">⚠️ Reportes pendientes sin atender</h2>'
    + '</div>'
    + '<div style="padding:20px;">'
    + '<p>Los siguientes reportes llevan más de <b>' + HORAS_LIMITE + ' horas</b> sin ser atendidos:</p>'
    + '<table style="width:100%;border-collapse:collapse;font-size:13px;">'
    + '<thead><tr style="background:#f0f2f5;">'
    + '<th style="padding:8px 10px;text-align:left;">Código</th>'
    + '<th style="padding:8px 10px;text-align:left;">Trabajador</th>'
    + '<th style="padding:8px 10px;text-align:left;">Empresa</th>'
    + '<th style="padding:8px 10px;text-align:left;">Lugar</th>'
    + '<th style="padding:8px 10px;text-align:left;">Recibido</th>'
    + '<th style="padding:8px 10px;text-align:left;">Espera</th>'
    + '</tr></thead>'
    + '<tbody>' + filasHtml + '</tbody>'
    + '</table>'
    + '<div style="margin-top:20px;text-align:center;">'
    + '<a href="' + urlPanel + '" style="background:#f0a500;color:#1c2b3a;padding:12px 28px;border-radius:6px;text-decoration:none;font-weight:700;">Ir al Panel del Inspector →</a>'
    + '</div></div></div>';

  MailApp.sendEmail({ to: INSPECTOR_PRINCIPAL, cc: COPIA, subject: asunto, htmlBody: htmlBody });
  Logger.log("⚠️ Alerta enviada: " + total + " reporte(s) pendiente(s).");
}
