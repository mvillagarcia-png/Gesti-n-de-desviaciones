    + '</div></div>';

  const adjuntos = [];
  const idsYaProcesados = new Set();

  listaUrls.forEach(function(url) {
    try {
      const matchId = url.match(/[-\w]{25,}/);
      if (!matchId) return;
      const fileId = matchId[0];
      if (idsYaProcesados.has(fileId)) return;
      idsYaProcesados.add(fileId);
      const archivo  = DriveApp.getFileById(fileId);
      const mimeType = archivo.getMimeType() || "";
      if (mimeType.startsWith("image/")) adjuntos.push(archivo.getBlob());
    } catch(e) {
      Logger.log("⚠️ No se pudo adjuntar: " + e.message);
    }
