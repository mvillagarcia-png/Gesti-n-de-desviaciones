  <script>
    // ════════════════════════════════════════════════
    // PANTALLA DE BIENVENIDA
    // ════════════════════════════════════════════════
    function elegirOpcion(opcion) {
      // Ocultar bienvenida
      document.getElementById("pantalla-bienvenida").style.display = "none";

      // Mostrar pestanas
      document.getElementById("tabs-wrap").classList.remove("hidden-tabs");

      // Activar la vista correcta
      if (opcion === "reporte") {
        document.getElementById("tab-reporte").classList.add("active");
        document.getElementById("tab-levantamiento").classList.remove("active");
        document.getElementById("view-reporte").style.display = "block";
        document.getElementById("view-levantamiento").style.display = "none";
        document.getElementById("progress-wrap").style.display = "flex";
      } else {
        document.getElementById("tab-levantamiento").classList.add("active");
        document.getElementById("tab-reporte").classList.remove("active");
        document.getElementById("view-levantamiento").style.display = "block";
        document.getElementById("view-reporte").style.display = "none";
        document.getElementById("progress-wrap").style.display = "none";
      }

      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    // ════════════════════════════════════════════════
    // NAVEGACION DE PESTANAS
    // ════════════════════════════════════════════════
    function cambiarTab(tab) {
      document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
      document.getElementById("tab-" + tab).classList.add("active");

      if (tab === "reporte") {
        document.getElementById("view-reporte").style.display = "block";
        document.getElementById("view-levantamiento").style.display = "none";
        document.getElementById("progress-wrap").style.display = "flex";
      } else {
        document.getElementById("view-levantamiento").style.display = "block";
        document.getElementById("view-reporte").style.display = "none";
        document.getElementById("progress-wrap").style.display = "none";
      }
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    // ════════════════════════════════════════════════
    // TOAST
    // ════════════════════════════════════════════════
    function showToast(msg, tipo = "ok") {
      const t = document.getElementById("toast");
      t.textContent = msg;
      t.className = "toast" + (tipo === "error" ? " error" : "");
      t.classList.add("show");
      setTimeout(() => t.classList.remove("show"), 3500);
    }

    // ════════════════════════════════════════════════
    // COMPRIMIR IMAGEN
    // ════════════════════════════════════════════════
    function comprimirImagen(file, maxPx, calidad, callback) {
      const reader = new FileReader();
      reader.onload = ev => {
        const img = new Image();
        img.onload = () => {
          let w = img.width, h = img.height;
          if (w > maxPx || h > maxPx) {
            if (w > h) { h = Math.round(h * maxPx / w); w = maxPx; }
            else { w = Math.round(w * maxPx / h); h = maxPx; }
          }
          const canvas = document.createElement("canvas");
          canvas.width = w; canvas.height = h;
          canvas.getContext("2d").drawImage(img, 0, 0, w, h);
          callback(canvas.toDataURL("image/jpeg", calidad));
        };
        img.src = ev.target.result;
      };
      reader.readAsDataURL(file);
    }

    // ════════════════════════════════════════════════
    // TAB 1: REPORTE — BARRA DE PROGRESO
    // ════════════════════════════════════════════════
    const requiredFields = ["nombres", "apellidos", "empresa", "lugar", "descripcion"];
    function updateProgress() {
      let filled = 0;
      requiredFields.forEach(id => {
        const el = document.getElementById(id);
        if (el && el.value.trim() !== "") filled++;
      });
      const pct = Math.round((filled / requiredFields.length) * 100);
      document.getElementById("progressFill").style.width = pct + "%";
      document.getElementById("progressLabel").textContent = filled + " / " + requiredFields.length;
    }
    requiredFields.forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.addEventListener("change", updateProgress); el.addEventListener("input", updateProgress); }
    });
    updateProgress();

    // Contadores de caracteres
    const descEl = document.getElementById("descripcion");
    const charEl = document.getElementById("charCount");
    descEl.addEventListener("input", () => {
      const len = descEl.value.length;
      charEl.textContent = len + " / 600";
      charEl.classList.toggle("warn", len > 500);
    });
    const propEl = document.getElementById("propuesta");
    const propCnt = document.getElementById("charCountPropuesta");
    propEl.addEventListener("input", () => {
      const len = propEl.value.length;
      propCnt.textContent = len + " / 400";
      propCnt.classList.toggle("warn", len > 300);
    });

    // ════════════════════════════════════════════════
    // MULTI-ARCHIVO REPORTE
    // ════════════════════════════════════════════════
    let repArchivos = [];

    function repDetectarTipo(file) {
      if (file.type.startsWith("image/")) return "foto";
      if (file.type.startsWith("video/")) return "video";
      return "otro";
    }
    function repFormatTamano(bytes) {
      if (bytes < 1024) return bytes + " B";
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + " KB";
      return (bytes / 1024 / 1024).toFixed(1) + " MB";
    }
    function repProcesarArchivos(fileList) {
      const MAX = 5;
      Array.from(fileList).forEach(file => {
        if (repArchivos.length >= MAX) { showToast("Maximo 5 archivos permitidos", "error"); return; }
        if (file.size > 50 * 1024 * 1024) { showToast(file.name + " supera los 50 MB", "error"); return; }
        const id = Date.now() + Math.random();
        const tipo = repDetectarTipo(file);
        repArchivos.push({ id, file, nombre: file.name, tipo, tamano: file.size, base64: "", estado: "procesando" });
        repRenderArchivos();
        if (tipo === "foto") {
          comprimirImagen(file, 1280, 0.75, function(b64) {
            const a = repArchivos.find(x => x.id === id);
            if (a) { a.base64 = b64; a.estado = "listo"; repRenderArchivos(); }
          });
        } else {
          const reader = new FileReader();
          reader.onload = ev => {
            const a = repArchivos.find(x => x.id === id);
            if (a) { a.base64 = ev.target.result; a.estado = "listo"; repRenderArchivos(); }
          };
          reader.readAsDataURL(file);
        }
      });
      document.getElementById("rep-fileInput").value = "";
    }
    function repRenderArchivos() {
      const lista = document.getElementById("rep-archivos-lista");
      document.getElementById("rep-count-archivos").textContent =
        `(${repArchivos.length} archivo${repArchivos.length !== 1 ? "s" : ""})`;
      lista.innerHTML = repArchivos.map(a => `
        <div class="archivo-item">
          <div class="archivo-icono">${a.tipo === "video" ? "&#127909;" : "&#128247;"}</div>
          <div class="archivo-info">
            <div class="archivo-nombre">${a.nombre}</div>
            <div class="archivo-size">${repFormatTamano(a.tamano)}</div>
            <div class="archivo-progreso">
              <div class="archivo-progreso-fill" style="width:${a.estado==='listo'?'100':a.estado==='procesando'?'40':'0'}%"></div>
            </div>
            <div class="archivo-estado ${a.estado==='listo'?'ok':a.estado==='error'?'error':'cargando'}">
              ${a.estado==='listo'?'Listo':a.estado==='error'?'Error':'Procesando...'}
            </div>
          </div>
          <button type="button" class="btn-quitar-archivo" onclick="repQuitarArchivo('${a.id}')">&#10005;</button>
        </div>
      `).join("");
    }
    function repQuitarArchivo(id) {
      repArchivos = repArchivos.filter(a => String(a.id) !== String(id));
      repRenderArchivos();
    }

    const repZona = document.getElementById("rep-archivos-zona");
    repZona.addEventListener("dragover", e => { e.preventDefault(); repZona.classList.add("drag-over"); });
    repZona.addEventListener("dragleave", () => repZona.classList.remove("drag-over"));
    repZona.addEventListener("drop", e => {
      e.preventDefault(); repZona.classList.remove("drag-over");
      repProcesarArchivos(e.dataTransfer.files);
    });

    // ════════════════════════════════════════════════
    // LOCALSTORAGE PERFIL
    // ════════════════════════════════════════════════
    const CAMPOS_PERFIL = ["nombres", "apellidos", "celular", "correo", "empresa"];
    const LS_KEY = "cssa_trabajador_perfil";
    function cargarPerfil() {
      try {
        const g = localStorage.getItem(LS_KEY);
        if (!g) return;
        const p = JSON.parse(g);
        let alguno = false;
        CAMPOS_PERFIL.forEach(id => {
          const el = document.getElementById(id);
          if (el && p[id]) { el.value = p[id]; alguno = true; }
        });
        if (alguno) { document.getElementById("bannerGuardado").style.display = "flex"; updateProgress(); }
      } catch(e) {}
    }
    function guardarPerfil(data) {
      try { const p = {}; CAMPOS_PERFIL.forEach(id => { if(data[id]) p[id]=data[id]; }); localStorage.setItem(LS_KEY, JSON.stringify(p)); } catch(e) {}
    }
    function borrarPerfil() {
      try { localStorage.removeItem(LS_KEY); } catch(e) {}
      CAMPOS_PERFIL.forEach(id => { const el = document.getElementById(id); if(el) el.value = ""; });
      document.getElementById("bannerGuardado").style.display = "none"; updateProgress(); showToast("Datos eliminados", "ok");
    }
    cargarPerfil();
    document.getElementById("btnBorrarDatos").addEventListener("click", borrarPerfil);

    // ════════════════════════════════════════════════
    // VALIDACION Y SUBMIT REPORTE
    // ════════════════════════════════════════════════
    function validarReporte() {
      const vNombres     = (document.getElementById("nombres")?.value || "").trim();
      const vApellidos   = (document.getElementById("apellidos")?.value || "").trim();
      const vEmpresa     = (document.getElementById("empresa")?.value || "").trim();
      const vLugar       = (document.getElementById("lugar")?.value || "").trim();
      const vDescripcion = (document.getElementById("descripcion")?.value || "").trim();
      const checks = [
        { id: "field-nombres",     invalid: !vNombres },
        { id: "field-apellidos",   invalid: !vApellidos },
        { id: "field-empresa",     invalid: !vEmpresa },
        { id: "field-lugar",       invalid: !vLugar },
        { id: "field-descripcion", invalid: !vDescripcion || vDescripcion.length < 10 },
      ];
      let ok = true;
      checks.forEach(c => { const el = document.getElementById(c.id); if(el) el.classList.toggle("invalid", c.invalid); if(c.invalid) ok = false; });
      return ok;
    }

    document.getElementById("reporteForm").addEventListener("submit", function(e) {
      e.preventDefault();
      if (!validarReporte()) { showToast("Completa los campos obligatorios", "error"); document.querySelector(".field.invalid")?.scrollIntoView({ behavior:"smooth", block:"center" }); return; }
      const procesando = repArchivos.filter(a => a.estado === "procesando");
      if (procesando.length > 0) { showToast("Espera a que los archivos terminen de procesarse", "error"); return; }

      const btn = document.getElementById("btnEnviar");
      const btnText = document.getElementById("btnText");
      const spinner = document.getElementById("spinner");
      btn.disabled = true; btnText.textContent = "Enviando..."; spinner.style.display = "block";

      const nombres   = document.getElementById("nombres").value.trim();
      const apellidos = document.getElementById("apellidos").value.trim();
      const data = {
        nombre: nombres + " " + apellidos, nombres, apellidos,
        celular: document.getElementById("celular").value.trim(),
        correo:  document.getElementById("correo").value.trim(),
        empresa: document.getElementById("empresa").value.trim(),
        areaReportante: document.getElementById("empresa").value.trim(),
        propuesta: document.getElementById("propuesta").value.trim(),
        fecha: new Date().toISOString().split("T")[0],
        lugar: document.getElementById("lugar").value.trim(),
        descripcion: document.getElementById("descripcion").value.trim(),
      };
      guardarPerfil(data);

      const archivosPayload = repArchivos.map(a => ({
        nombre: a.nombre, tipo: a.tipo, base64: a.base64,
      }));

      google.script.run
        .withSuccessHandler(function() {
          document.getElementById("form-section").style.display = "none";
          document.getElementById("success-screen").style.display = "flex";
          window.scrollTo({ top: 0, behavior: "smooth" });
        })
        .withFailureHandler(function(err) {
          showToast("Error al enviar: " + err.message, "error");
          btn.disabled = false; btnText.textContent = "Enviar Reporte"; spinner.style.display = "none";
        })
        .registrarReporteTrabajador(data, archivosPayload);
    });

    document.getElementById("btnNuevo").addEventListener("click", () => {
      document.getElementById("lugar").value = "";
      document.getElementById("descripcion").value = "";
      document.getElementById("propuesta").value = "";
      document.querySelectorAll("#reporteForm .field.invalid").forEach(f => f.classList.remove("invalid"));
      repArchivos = []; repRenderArchivos();
      document.getElementById("rep-fileInput").value = "";
      charEl.textContent = "0 / 600"; propCnt.textContent = "0 / 400";
      const btnEnv = document.getElementById("btnEnviar");
      btnEnv.disabled = false; document.getElementById("btnText").textContent = "Enviar Reporte"; document.getElementById("spinner").style.display = "none";
      document.getElementById("success-screen").style.display = "none";
      document.getElementById("form-section").style.display = "block";
      updateProgress(); window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // ════════════════════════════════════════════════
    // TAB 2: LEVANTAMIENTO
    // ════════════════════════════════════════════════
    let levArchivos = [];

    function actualizarReloj() {
      const ahora = new Date();
      const opciones = { day: "2-digit", month: "2-digit", year: "numeric", hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false };
      document.getElementById("lev-fechaHora").textContent = ahora.toLocaleString("es-PE", opciones);
    }
    setInterval(actualizarReloj, 1000);
    actualizarReloj();

    const levDescEl = document.getElementById("lev-descripcion");
    const levCharEl = document.getElementById("lev-charCount");
    levDescEl.addEventListener("input", () => {
      const len = levDescEl.value.length;
      levCharEl.textContent = len + " / 600";
      levCharEl.classList.toggle("warn", len > 500);
    });

    const levZona = document.getElementById("lev-archivos-zona");
    levZona.addEventListener("dragover", e => { e.preventDefault(); levZona.classList.add("drag-over"); });
    levZona.addEventListener("dragleave", () => levZona.classList.remove("drag-over"));
    levZona.addEventListener("drop", e => {
      e.preventDefault(); levZona.classList.remove("drag-over");
      levProcesarArchivos(e.dataTransfer.files);
    });

    function levDetectarTipo(file) {
      if (file.type.startsWith("image/")) return "foto";
      if (file.type.startsWith("video/")) return "video";
      return "otro";
    }
    function levFormatTamano(bytes) {
      if (bytes < 1024) return bytes + " B";
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + " KB";
      return (bytes / 1024 / 1024).toFixed(1) + " MB";
    }
    function levProcesarArchivos(fileList) {
      const MAX = 10;
      Array.from(fileList).forEach(file => {
        if (levArchivos.length >= MAX) { showToast("Maximo 10 archivos", "error"); return; }
        if (file.size > 50 * 1024 * 1024) { showToast(file.name + " supera 50 MB", "error"); return; }
        const id = Date.now() + Math.random();
        const tipo = levDetectarTipo(file);
        levArchivos.push({ id, file, nombre: file.name, tipo, tamano: file.size, base64: "", estado: "procesando" });
        levRenderArchivos();
        if (tipo === "foto") {
          comprimirImagen(file, 1280, 0.75, function(b64) {
            const a = levArchivos.find(x => x.id === id);
            if (a) { a.base64 = b64; a.estado = "listo"; levRenderArchivos(); }
          });
        } else {
          const reader = new FileReader();
          reader.onload = ev => {
            const a = levArchivos.find(x => x.id === id);
            if (a) { a.base64 = ev.target.result; a.estado = "listo"; levRenderArchivos(); }
          };
          reader.readAsDataURL(file);
        }
      });
    }
    function levRenderArchivos() {
      const lista = document.getElementById("lev-archivos-lista");
      document.getElementById("lev-count-archivos").textContent = `(${levArchivos.length} archivo${levArchivos.length !== 1 ? "s" : ""})`;
      lista.innerHTML = levArchivos.map(a => `
        <div class="archivo-item">
          <div class="archivo-icono">${a.tipo === "video" ? "&#127909;" : "&#128247;"}</div>
          <div class="archivo-info">
            <div class="archivo-nombre">${a.nombre}</div>
            <div class="archivo-size">${levFormatTamano(a.tamano)}</div>
            <div class="archivo-progreso">
              <div class="archivo-progreso-fill" style="width:${a.estado==='listo'?'100':a.estado==='procesando'?'40':'0'}%"></div>
            </div>
            <div class="archivo-estado ${a.estado==='listo'?'ok':a.estado==='error'?'error':'cargando'}">
              ${a.estado==='listo'?'Listo':a.estado==='error'?'Error':'Procesando...'}
            </div>
          </div>
          <button type="button" class="btn-quitar-archivo" onclick="levQuitarArchivo('${a.id}')">&#10005;</button>
        </div>
      `).join("");
    }
    function levQuitarArchivo(id) {
      levArchivos = levArchivos.filter(a => String(a.id) !== String(id));
      levRenderArchivos();
    }

    function validarLevantamiento() {
      const nombre = ($("#lev-nombre").val() || "").trim();
      const codigo = ($("#lev-codigo").val() || "").trim();
      const desc   = (document.getElementById("lev-descripcion").value || "").trim();
      const checks = [
        { id: "lev-field-nombre",      invalid: !nombre },
        { id: "lev-field-codigo",      invalid: !codigo },
        { id: "lev-field-descripcion", invalid: !desc || desc.length < 10 },
      ];
      let ok = true;
      checks.forEach(c => { const el = document.getElementById(c.id); if(el) el.classList.toggle("invalid", c.invalid); if(c.invalid) ok = false; });
      if (levArchivos.length === 0) { showToast("Agrega al menos un archivo de evidencia", "error"); ok = false; }
      const procesando = levArchivos.filter(a => a.estado === "procesando");
      if (procesando.length > 0) { showToast("Espera a que los archivos terminen de procesarse", "error"); ok = false; }
      return ok;
    }

    document.getElementById("levantamientoForm").addEventListener("submit", function(e) {
      e.preventDefault();
      if (!validarLevantamiento()) {
        showToast("Completa todos los campos obligatorios", "error");
        document.querySelector("#levantamientoForm .field.invalid")?.scrollIntoView({ behavior:"smooth", block:"center" });
        return;
      }
      const btn     = document.getElementById("lev-btnEnviar");
      const btnText = document.getElementById("lev-btnText");
      const spinner = document.getElementById("lev-spinner");
      btn.disabled = true; btnText.textContent = "Enviando evidencia..."; spinner.style.display = "block";

      const ahora = new Date();
      const datos = {
        nombre:      $("#lev-nombre").val() || "",
        codigo:      $("#lev-codigo").val() || "",
        descripcion: document.getElementById("lev-descripcion").value.trim(),
        fechaHora:   ahora.toISOString(),
        archivos: levArchivos.map(a => ({ nombre: a.nombre, tipo: a.tipo, base64: a.base64 })),
      };

      google.script.run
        .withSuccessHandler(function(res) {
          document.getElementById("lev-success-codigo").textContent =
            "Desviacion " + res.codigo + " - " + res.archivos + " archivo(s) enviado(s)";
          document.getElementById("form-lev-section").style.display = "none";
          document.getElementById("lev-success-screen").style.display = "flex";
          window.scrollTo({ top: 0, behavior: "smooth" });
        })
        .withFailureHandler(function(err) {
          showToast("Error al enviar: " + err.message, "error");
          btn.disabled = false; btnText.textContent = "Enviar Levantamiento"; spinner.style.display = "none";
        })
        .registrarLevantamiento(datos);
    });

    document.getElementById("lev-btnNuevo").addEventListener("click", () => {
      levArchivos = []; levRenderArchivos();
      $("#lev-nombre").val("").trigger("change");
      $("#lev-codigo").val("").trigger("change");
      document.getElementById("lev-descripcion").value = "";
      document.getElementById("lev-desv-box").classList.remove("visible");
      levCharEl.textContent = "0 / 600";
      document.querySelectorAll("#levantamientoForm .field.invalid").forEach(f => f.classList.remove("invalid"));
      document.getElementById("lev-fileInput").value = "";
      const btn = document.getElementById("lev-btnEnviar");
      btn.disabled = false; document.getElementById("lev-btnText").textContent = "Enviar Levantamiento"; document.getElementById("lev-spinner").style.display = "none";
      document.getElementById("lev-success-screen").style.display = "none";
      document.getElementById("form-lev-section").style.display = "block";
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // ════════════════════════════════════════════════
    // SELECT2
    // ════════════════════════════════════════════════
    document.addEventListener("DOMContentLoaded", function() {
      $(".select-buscable-lev").select2({
        width: "100%",
        placeholder: "Escribe para buscar",
        allowClear: true
      });

      $("#lev-codigo").on("change", function() {
        const opt = $(this).find("option:selected");
        const codigo = $(this).val() || "";
        const box = document.getElementById("lev-desv-box");
        if (codigo) {
          document.getElementById("lev-desv-detalle").textContent = opt.data("detalle") || "-";
          document.getElementById("lev-desv-meta").textContent =
            "Responsable: " + (opt.data("responsable") || "-") +
            "  -  Area: " + (opt.data("area") || "-") +
            "  -  Estatus: " + (opt.data("estatus") || "-") +
            "  -  Fecha limite: " + (opt.data("fechalimite") || "-");
          box.classList.add("visible");
          document.getElementById("lev-field-codigo").classList.remove("invalid");
        } else {
          box.classList.remove("visible");
        }
      });
    });
  </script>

</body>
