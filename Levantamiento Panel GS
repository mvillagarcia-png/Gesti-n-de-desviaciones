// 5. RECHAZAR LEVANTAMIENTO
// ============================================================
function rechazarLevantamiento(codigo, filaLev, inspector, motivo) {
  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const tz    = Session.getScriptTimeZone();
  const ahora = new Date();
  const fechaStr = Utilities.formatDate(ahora, tz, "dd/MM/yyyy HH:mm");

  const hLev = ss.getSheetByName(HOJA_LEV);
  let nombreResponsable = "";
  let descripcionLev    = "";
  if (hLev && filaLev >= 2) {
    nombreResponsable = String(hLev.getRange(filaLev, 3).getValue() || "").trim();
    descripcionLev    = String(hLev.getRange(filaLev, 4).getValue() || "").trim();
    hLev.getRange(filaLev, 8).setValue("RECHAZADO");
    hLev.getRange(filaLev, 9).setValue(fechaStr);
    hLev.getRange(filaLev, 10).setValue(inspector || "Inspector SMA");
    hLev.getRange(filaLev, 11).setValue(motivo || "");
    hLev.getRange(filaLev, 1, 1, 11).setBackground("#fee2e2");
    Logger.log("🚫 Levantamiento fila " + filaLev + " RECHAZADO. Motivo: " + motivo);
  }

  let emailResponsable  = "";
  let detalleDesviacion = "";
  let areaDesviacion    = "";
  let fechaLimiteStr    = "";

  const hAcum = ss.getSheetByName(HOJA_ACUM);
  if (hAcum && hAcum.getLastRow() > 1) {
    const datosAcum = hAcum.getRange(2, 1, hAcum.getLastRow() - 1, COL_ESTATUS_ACUM).getValues();
    for (let i = 0; i < datosAcum.length; i++) {
      if (String(datosAcum[i][COL_CODIGO_ACUM - 1]).trim() === String(codigo).trim()) {
        emailResponsable  = String(datosAcum[i][35] || "").trim();
        detalleDesviacion = String(datosAcum[i][COL_DETALLE_ACUM - 1] || "").trim();
        areaDesviacion    = String(datosAcum[i][COL_AREA_ACUM - 1]    || "").trim();
        const rawFLim     = datosAcum[i][COL_FECHA_LIM - 1];
        if (rawFLim instanceof Date && !isNaN(rawFLim)) {
          fechaLimiteStr = Utilities.formatDate(rawFLim, tz, "dd/MM/yyyy");
        }
        break;
      }
    }
  }

  if (emailResponsable && emailResponsable.includes("@")) {
    try {
      _enviarCorreoRechazo({
        emailResponsable, nombreResponsable, codigo,
        detalleDesviacion, areaDesviacion, fechaLimiteStr,
        descripcionLev, motivo, inspector, fechaRechazo: fechaStr
      });
      Logger.log("📧 Correo de rechazo enviado a: " + emailResponsable);
    } catch(e) {
      Logger.log("⚠️ Error enviando correo de rechazo: " + e.message);
    }
  }

  return { ok: true };
}

