// 6. OBTENER LEVANTAMIENTOS PENDIENTES — CORREGIDO
//    Muestra código correcto + detalle completo de la desviación
// ============================================================
function obtenerLevantamientosPendientes() {
  try {
    const ss    = SpreadsheetApp.getActiveSpreadsheet();
    const hLev  = ss.getSheetByName(HOJA_LEV);
    const hAcum = ss.getSheetByName(HOJA_ACUM);
    if (!hLev || hLev.getLastRow() < 2) return [];

    const tz = Session.getScriptTimeZone();

    // ── Construir mapa código → datos completos de Acumulado ──
    // Leemos todas las columnas relevantes de Acumulado de una vez
    const mapaAcum = {};
    if (hAcum && hAcum.getLastRow() > 1) {
      const totalCols = COL_ESTATUS_ACUM; // hasta col AM
      const filas = hAcum.getRange(2, 1, hAcum.getLastRow() - 1, totalCols).getValues();
      filas.forEach(fila => {
        // col C = índice 2 (0-based)
        const cod = String(fila[COL_CODIGO_ACUM - 1] || "").trim();
        if (!cod) return;

        // Fecha límite formateada
        let fechaLimStr = "";
        const rawFL = fila[COL_FECHA_LIM - 1];
        if (rawFL instanceof Date && !isNaN(rawFL)) {
          fechaLimStr = Utilities.formatDate(rawFL, tz, "dd/MM/yyyy");
        } else if (rawFL) {
          fechaLimStr = String(rawFL).trim();
        }

        mapaAcum[cod] = {
          detalle:     String(fila[COL_DETALLE_ACUM - 1] || "").trim(),   // col W
          responsable: String(fila[COL_RESP_ACUM - 1]    || "").trim(),   // col AI
          area:        String(fila[COL_AREA_ACUM - 1]    || "").trim(),   // col AK
          estatus:     String(fila[COL_ESTATUS_ACUM - 1] || "").trim(),   // col AM
          fechaLimite: fechaLimStr,
          // Columnas adicionales para mostrar en panel
          aspecto:     String(fila[11] || "").trim(),  // col L
          clase:       String(fila[12] || "").trim(),  // col M
          criticidad:  String(fila[27] || "").trim(),  // col AB
          accionCorrectiva: String(fila[32] || "").trim(), // col AG
        };
      });
    }

    // ── Leer hoja Levantamientos ──
    const datos  = hLev.getRange(2, 1, hLev.getLastRow() - 1, 11).getValues();
    const result = [];

    datos.forEach((fila, i) => {
      const estado = String(fila[7] || "").trim().toUpperCase();
      if (estado !== "PENDIENTE") return;

      // Col B (índice 1) = CÓDIGO DESVIACIÓN — debe ser string limpio como "2026-001"
      const codigoLev = String(fila[1] || "").trim();

      // Validar que el código tenga formato esperado (no sea una fecha ni vacío)
      if (!codigoLev || codigoLev === "") {
        Logger.log("⚠️ Fila " + (i + 2) + " sin código válido, se omite.");
        return;
      }

      // Fecha envío
      const fechaRaw = fila[4];
      let fechaStr   = "";
      if (fechaRaw instanceof Date && !isNaN(fechaRaw)) {
        fechaStr = Utilities.formatDate(fechaRaw, tz, "dd/MM/yyyy HH:mm");
      } else {
        fechaStr = String(fechaRaw || "").trim();
      }

      const urls = String(fila[6] || "").split(" | ").filter(Boolean);

      // Datos de Acumulado para esta desviación
      const datosDes = mapaAcum[codigoLev] || {};

      result.push({
        filaLev:     i + 2,
        id:          fila[0],
        codigo:      codigoLev,                                    // ← código correcto siempre
        nombre:      String(fila[2] || "").trim(),
        descripcion: String(fila[3] || "").trim(),
        fechaEnvio:  fechaStr,
        numArchivos: Number(fila[5] || 0),
        urls:        urls,
        estado:      estado,

        // ── Datos de la desviación original (desde Acumulado) ──
        detalleObservacion: datosDes.detalle     || "",
        responsable:        datosDes.responsable || "",
        area:               datosDes.area        || "",
        estatusDesviacion:  datosDes.estatus     || "",
        fechaLimite:        datosDes.fechaLimite || "",
        aspecto:            datosDes.aspecto     || "",
        clase:              datosDes.clase       || "",
        criticidad:         datosDes.criticidad  || "",
        accionCorrectiva:   datosDes.accionCorrectiva || "",
      });
    });

    result.sort((a, b) => b.filaLev - a.filaLev);
    Logger.log("obtenerLevantamientosPendientes → " + result.length + " pendientes");
    return result;

  } catch(e) {
    Logger.log("Error obtenerLevantamientosPendientes: " + e.message);
    return [];
  }
}
