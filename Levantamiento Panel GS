// ============================================================
// 1. OBTENER DESVIACIONES PENDIENTES PARA EL SELECTOR HTML
// ============================================================
function obtenerDesviacionesPendientesLev() {
  try {
    const ss    = SpreadsheetApp.getActiveSpreadsheet();
    const hAcum = ss.getSheetByName(HOJA_ACUM);
    if (!hAcum || hAcum.getLastRow() < 2) return [];

    const tz         = Session.getScriptTimeZone();
    const ultimaFila = hAcum.getLastRow();
    const datos      = hAcum.getRange(2, 1, ultimaFila - 1, COL_ESTATUS_ACUM).getValues();

    const resultado = [];
    datos.forEach(fila => {
      const codigo  = String(fila[COL_CODIGO_ACUM - 1]  || "").trim();
      const estatus = String(fila[COL_ESTATUS_ACUM - 1] || "").trim();
      const detalle = String(fila[COL_DETALLE_ACUM - 1] || "").trim();
      const resp    = String(fila[COL_RESP_ACUM - 1]    || "").trim();
      const area    = String(fila[COL_AREA_ACUM - 1]    || "").trim();

      if (!codigo) return;

      const estatusNorm = estatus.toLowerCase();
      if (estatusNorm !== "en plazo" && estatusNorm !== "pendiente") return;

      let fechaLimStr = "";
      const rawFechaLim = fila[COL_FECHA_LIM - 1];
      if (rawFechaLim instanceof Date && !isNaN(rawFechaLim)) {
        fechaLimStr = Utilities.formatDate(rawFechaLim, tz, "dd/MM/yyyy");
      } else if (rawFechaLim) {
        fechaLimStr = String(rawFechaLim).trim();
      }

      resultado.push({
        codigo:      codigo,
        detalle:     detalle.substring(0, 120) || "Sin descripción",
        responsable: resp  || "—",
        area:        area  || "—",
        estatus:     estatus,
        fechaLimite: fechaLimStr,
      });
    });

    resultado.sort((a, b) => b.codigo.localeCompare(a.codigo));
    Logger.log("obtenerDesviacionesPendientesLev → " + resultado.length + " desviaciones encontradas");
    return resultado;

  } catch(e) {
    Logger.log("Error obtenerDesviacionesPendientesLev: " + e.message);
    return [];
  }
}

// ============================================================
// 2. REGISTRAR LEVANTAMIENTO
// ============================================================
function registrarLevantamiento(datos) {

  if (!datos.codigo)                              throw new Error("Código de desviación requerido.");
  if (!datos.nombre)                              throw new Error("Nombre del responsable requerido.");
  if (!datos.archivos || datos.archivos.length === 0) throw new Error("No se recibieron archivos de evidencia.");

  const ss  = SpreadsheetApp.getActiveSpreadsheet();
  const tz  = Session.getScriptTimeZone();

  // ── A. Garantizar hoja "Levantamientos" ──
  let hLev = ss.getSheetByName(HOJA_LEV);
  if (!hLev) {
    hLev = ss.insertSheet(HOJA_LEV);
    hLev.appendRow([
      "ID", "CÓDIGO DESVIACIÓN", "NOMBRE RESPONSABLE",
      "DESCRIPCIÓN LEVANTAMIENTO", "FECHA Y HORA ENVÍO",
      "N° ARCHIVOS", "URLs ARCHIVOS", "ESTADO VALIDACIÓN",
      "FECHA VALIDACIÓN", "INSPECTOR QUE VALIDÓ", "OBSERVACIÓN INSPECTOR"
    ]);
    hLev.getRange(1, 1, 1, 11)
      .setBackground("#111111").setFontColor("#CE000C")
      .setFontWeight("bold").setFontSize(11);
    hLev.setFrozenRows(1);
    hLev.setColumnWidths(1, 11, 160);
    Logger.log("✅ Hoja 'Levantamientos' creada.");
  }

  const idLev = hLev.getLastRow();

  // ── B. Parsear fecha ──
  let fechaEnvio;
  try {
    fechaEnvio = new Date(datos.fechaHora);
    if (isNaN(fechaEnvio)) fechaEnvio = new Date();
  } catch(e) { fechaEnvio = new Date(); }
  const fechaEnvioStr = Utilities.formatDate(fechaEnvio, tz, "dd/MM/yyyy HH:mm:ss");

  // ── C. Crear subcarpeta en Drive ──
  let subcarpeta;
  try {
    const carpetaRaiz  = DriveApp.getFolderById(CARPETA_LEV_ID);
    const iterCarpetas = carpetaRaiz.getFoldersByName(datos.codigo);
    subcarpeta = iterCarpetas.hasNext() ? iterCarpetas.next() : carpetaRaiz.createFolder(datos.codigo);
  } catch(e) {
    Logger.log("⚠️ Error accediendo a carpeta Drive: " + e.message);
    throw new Error("No se pudo acceder a la carpeta de Drive. ID: " + CARPETA_LEV_ID);
  }

  // ── D. Subir archivos ──
  const archivosSubidos = [];
  datos.archivos.forEach((arch, idx) => {
    try {
      const b64Limpio = arch.base64.includes(",") ? arch.base64.split(",")[1] : arch.base64;
      if (!b64Limpio) { Logger.log("⚠️ Archivo vacío: " + arch.nombre); return; }

      let mimeType = "image/jpeg";
      if (arch.tipo === "video")                             mimeType = "video/mp4";
      else if (arch.tipo === "pdf")                          mimeType = "application/pdf";
      else if (arch.base64.includes("data:image/png"))       mimeType = "image/png";
      else if (arch.base64.includes("data:video/"))          mimeType = "video/mp4";
      else if (arch.base64.includes("data:application/pdf")) mimeType = "application/pdf";

      const ext          = arch.tipo === "video" ? ".mp4" : arch.tipo === "pdf" ? ".pdf" : ".jpg";
      const nombreDrive  = datos.codigo + "_" + (idx + 1) + "_" + arch.nombre.replace(/[^a-zA-Z0-9._-]/g, "_");
      const blob         = Utilities.newBlob(Utilities.base64Decode(b64Limpio), mimeType, nombreDrive);
      const archivo      = subcarpeta.createFile(blob);
      archivo.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);

      archivosSubidos.push({ nombre: arch.nombre, url: archivo.getUrl(), tipo: arch.tipo });
      Logger.log("📁 Archivo subido: " + nombreDrive);
    } catch(e) {
      Logger.log("⚠️ Error subiendo " + arch.nombre + ": " + e.message);
    }
  });

  if (archivosSubidos.length === 0) {
    throw new Error("No se pudo subir ningún archivo a Drive. Verifica los permisos de la carpeta.");
  }

  const urlsStr = archivosSubidos.map(a => a.url).join(" | ");

  // ── E. Escribir fila en "Levantamientos" ──
  hLev.appendRow([
    idLev,
    datos.codigo,
    datos.nombre,
    datos.descripcion,
    fechaEnvio,
    archivosSubidos.length,
    urlsStr,
    "PENDIENTE",
    "", "", ""
  ]);

  const uF = hLev.getLastRow();
  hLev.getRange(uF, 5).setNumberFormat("dd/MM/yyyy HH:mm:ss");
  hLev.getRange(uF, 1, 1, 11).setBackground("#fff9e6");

  // ── F. Alertar al inspector ──
  _enviarAlertaLevantamiento(datos, archivosSubidos, fechaEnvioStr, idLev);

  Logger.log("✅ Levantamiento registrado: ID=" + idLev + " | Código=" + datos.codigo + " | " + archivosSubidos.length + " archivos");
  return { codigo: datos.codigo, archivos: archivosSubidos.length };
}

