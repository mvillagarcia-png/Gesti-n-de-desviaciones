const COL_CODIGO_ACUM   = 3;    // columna C  (1-indexed)
const COL_DETALLE_ACUM  = 23;   // columna W  (1-indexed)
const COL_RESP_ACUM     = 35;   // columna AI (1-indexed)
const COL_AREA_ACUM     = 37;   // columna AK (1-indexed)
const COL_FECHA_LIM     = 38;   // columna AL (1-indexed)
