  hBand.getRange(numFilaBandeja, 14).setValue("ATENDIDO");           // N: Estado
  hBand.getRange(numFilaBandeja, 1, 1, 14).setBackground("#e6f6ed");   // Verde claro

  // 6) Agregar nota de trazabilidad: código RPT → código Acumulado
  const nota = hBand.getRange(numFilaBandeja, 3).getNote() || "";
  hBand.getRange(numFilaBandeja, 3)
    .setNote((nota ? nota + "\n" : "") + "→ Acumulado: " + codigoAcumulado);

  Logger.log("✅ Reporte " + codigoRef + " → Acumulado: " + codigoAcumulado);

  // Enviar correo de confirmación al trabajador si dejó correo
  const correoTrabajador = filaBandeja[6] || ""; // col G = correo
  if (correoTrabajador.trim() !== "") {
    try {
      const nombreTrabajador = filaBandeja[3] || "";
      const asunto = "✅ Tu reporte fue registrado · " + codigoAcumulado + " · CSSA SMA";
      const htmlBody = `
        <div style="font-family:Arial,sans-serif; max-width:600px; margin:0 auto; background:#f5f7fa; padding:24px;">
          <div style="background:white; border-radius:12px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
            <div style="background:#0058a3; padding:24px 28px;">
              <div style="color:white; font-size:20px; font-weight:700;">✅ Reporte Registrado Oficialmente</div>
              <div style="color:rgba(255,255,255,0.85); font-size:13px; margin-top:4px;">CSSA · Seguridad y Medio Ambiente</div>
            </div>
