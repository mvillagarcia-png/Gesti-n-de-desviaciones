/**
 * Devuelve todos los reportes de la hoja "Bandeja de Entrada"
 * como array de objetos, listos para renderizar en la tabla.
 */
function obtenerReportesBandeja() {
  const ss   = SpreadsheetApp.getActiveSpreadsheet();
  const hoja = ss.getSheetByName("Bandeja de Entrada");
  if (!hoja || hoja.getLastRow() < 2) return [];

  const datos = hoja.getDataRange().getValues();
  const result = [];

  for (let i = 1; i < datos.length; i++) {
    const fila = datos[i];

    // Formato de fechas
    const tz = Session.getScriptTimeZone();
    let fechaEvento  = "";
    let fechaReporte = "";

    if (fila[1] instanceof Date && !isNaN(fila[1])) {
      fechaReporte = Utilities.formatDate(fila[1], tz, "dd/MM/yyyy HH:mm");
    }
    if (fila[8] instanceof Date && !isNaN(fila[8])) {
      fechaEvento = Utilities.formatDate(fila[8], tz, "dd/MM/yyyy");  // col I
    }

    result.push({
      id:           i + 1,  // número de fila real en Sheets (fila 1 = header)
      fechaReporte: fechaReporte,
      codigoRef:    String(fila[2]  || ""),
      nombre:       String(fila[3]  || ""),
      apellidos:    String(fila[4]  || ""),
      celular:      String(fila[5]  || ""),
      correo:       String(fila[6]  || ""),
      empresa:      String(fila[7]  || ""),
      fechaEvento:  fechaEvento,
      lugar:        String(fila[9]  || ""),
      descripcion:  String(fila[10] || ""),
      imgUrl:       String(fila[11] || ""),
      propuesta:    String(fila[12] || ""),
      estado:       String(fila[13] || ""),
    });
  }

  // Ordenar: PENDIENTES primero, luego por fecha descendente
  result.sort((a, b) => {
    if (a.estado === "PENDIENTE" && b.estado !== "PENDIENTE") return -1;
    if (a.estado !== "PENDIENTE" && b.estado === "PENDIENTE") return 1;
    return b.id - a.id;
  });

  return result;
}


