                <div style="font-size:28px; font-weight:700; color:#1c2b3a; letter-spacing:2px;">${codigoAcumulado}</div>
                <div style="font-size:12px; color:#718096; margin-top:4px;">Guarda este código para seguimiento</div>
              </div>
              <p style="color:#4a5568; font-size:14px; line-height:1.6; margin:0 0 24px;">
                El equipo de Seguridad y Medio Ambiente gestionará las acciones correctivas correspondientes.
              </p>
