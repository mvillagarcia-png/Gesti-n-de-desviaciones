/**
 * Combina los datos del trabajador (Bandeja) con los del inspector
 * y llama a registrarFormulario() para guardar en "Acumulado".
 * Luego marca el reporte en Bandeja como ATENDIDO.
 *
 * @param {number} reporteId    - ID del reporte en Bandeja de Entrada
 * @param {string} codigoRef    - Código RPT del reporte (para trazabilidad)
 * @param {Object} datosInspector - Campos completados por el inspector
 * @returns {string} - Código del item en Acumulado (ej: "2025-042")
 */
function validarYPasarAcumulado(reporteId, codigoRef, datosInspector, base64Inspector) {

  // 1) Leer fila original de Bandeja de Entrada
  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const hBand = ss.getSheetByName("Bandeja de Entrada");
  if (!hBand) throw new Error("Hoja 'Bandeja de Entrada' no encontrada.");

  // reporteId ES el número de fila real en Sheets
  const numFilaBandeja = Number(reporteId);
  const datos = hBand.getDataRange().getValues();
  if (numFilaBandeja < 2 || numFilaBandeja > hBand.getLastRow()) {
    throw new Error("Fila " + numFilaBandeja + " fuera de rango en Bandeja.");
  }
  const filaBandeja = datos[numFilaBandeja - 1]; // getValues() es 0-indexed

  // 2) Reconstruir el objeto formData completo que espera registrarFormulario()
  //    Combina datos del trabajador + datos del inspector
  const tz = Session.getScriptTimeZone();

  // Fecha del evento (viene como Date desde Sheets o como string del inspector)
  let fechaEventoStr = datosInspector.fecha || "";
  if (filaBandeja[8] instanceof Date && !isNaN(filaBandeja[8])) {  // col I
    fechaEventoStr = Utilities.formatDate(filaBandeja[8], tz, "yyyy-MM-dd");
    // Convertir a formato dd/MM/yyyy que espera registrarFormulario
    const partes = fechaEventoStr.split("-");
    fechaEventoStr = partes[2] + "/" + partes[1] + "/" + partes[0];
  }

  // Fecha límite: viene en formato yyyy-MM-dd del input date del inspector
  let fechaLimiteStr = datosInspector.fechaLimite || "";
  if (fechaLimiteStr.includes("-")) {
    const p = fechaLimiteStr.split("-");
    fechaLimiteStr = p[2] + "/" + p[1] + "/" + p[0];
  }

  // 3) Resolver imagen — usar la del trabajador o guardar la del inspector
  let imgUrl = filaBandeja[11] || "";  // L: imagen del trabajador

  if ((!imgUrl || imgUrl === "") && base64Inspector && base64Inspector.length > 100) {
    try {
      const carpetaId = "1bxN0M9JjKgzGMmLCYxWkEBW0ByIQh_0M";
      const carpeta   = DriveApp.getFolderById(carpetaId);
      const contenido = base64Inspector.includes(",") ? base64Inspector.split(",")[1] : base64Inspector;
      const blob      = Utilities.newBlob(
        Utilities.base64Decode(contenido),
        "image/jpeg",
        "INSP-" + reporteId + "_inspector.jpg"
      );
      const archivo = carpeta.createFile(blob);
      archivo.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
      imgUrl = archivo.getUrl();
      hBand.getRange(numFilaBandeja, 12).setValue(imgUrl);
      Logger.log("📷 Foto del inspector guardada: " + imgUrl);
    } catch(e) {
      Logger.log("⚠️ Error guardando foto del inspector: " + e.message);
    }
  }

  const formData = {
    // ── Del trabajador ──────────────────────────────
    fecha:            fechaEventoStr,
    lugar:            filaBandeja[9]  || "",  // J
    detalle:          datosInspector.detalle || filaBandeja[10] || "",  // inspector edita primero, trabajador como fallback
    quienReporta:     datosInspector.quienReporta || "8.VÍA WHATSAPP",
    nombreReportante: datosInspector.nombreReportante || filaBandeja[3] || "",
    areaReportante:   datosInspector.areaReportante   || filaBandeja[7] || "",

    // ── Del inspector ───────────────────────────────
    unidad:           datosInspector.unidad           || "",
    aspecto:          datosInspector.aspecto           || "",
    claseEvento:      datosInspector.claseEvento       || "",
    severidadEvento:  datosInspector.severidadEvento   || "",
    diasPerdidos:     datosInspector.diasPerdidos      || "",
    empresa:          datosInspector.empresa           || "",
    area:             datosInspector.area              || filaBandeja[7] || "",
    tipificacion:     datosInspector.tipificacion      || "",
    desglose1:        datosInspector.desglose1         || "",
    desglose2:        datosInspector.desglose2         || "",
    actoCondicion:    datosInspector.actoCondicion     || "",
    probabilidad:     datosInspector.probabilidad      || "",
    severidadTexto:   datosInspector.severidadTexto    || "",
    criticidad:       datosInspector.criticidad        || "",
    nombreRelacion1:  datosInspector.nombreRelacion1   || "",
    nombreRelacion2:  datosInspector.nombreRelacion2   || "",
    causasInmediatas: datosInspector.causasInmediatas  || "",
    causasBasicas:    datosInspector.causasBasicas     || "",
    accionCorrectiva: datosInspector.accionCorrectiva  || "",
    accionPreventiva: datosInspector.accionPreventiva  || "",
    responsable:      datosInspector.responsable       || "",
    fechaLimite:      fechaLimiteStr,
    status:           datosInspector.status            || "",
    _imgUrlExistente: imgUrl || "",  // imagen resuelta (trabajador o inspector)
  };

  const resultado = registrarFormulario(formData, null);
  // registrarFormulario devuelve "✅ ITEM YYYY-NNN registrado con éxito."
  // Extraemos solo el código
  const codigoAcumulado = resultado.replace("✅ ITEM ", "").replace(" registrado con éxito.", "");

  // 4) Si había imagen, actualizar la celda de la nueva fila en Acumulado
  //    con el link de Drive que ya existe
  if (imgUrl) {
    const hAcum = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Acumulado");
    if (hAcum) {
      const uF = hAcum.getLastRow();
      hAcum.getRange("AX" + uF).setFormula(`=HYPERLINK("${imgUrl}", "ver imagen")`);
      hAcum.getRange("AY" + uF).setValue(imgUrl);
    }
  }

  // 5) Marcar reporte en Bandeja como ATENDIDO
  const ahora     = new Date();
